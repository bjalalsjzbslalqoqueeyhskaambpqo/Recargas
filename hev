	"net/http"
	"os"
	"path/filepath"
	"strconv"
	"strings"
	"sync"
	"time"
)

const (
	panelAddr = "0.0.0.0:8090"
	usersPath = "/opt/btserver/users.txt"
	tokenPath = "/opt/btserver/token.txt"
	kickBase  = "http://127.0.0.1:8091/kick?id="
)

var (
	token     string
	tokenOnce sync.Once
	usersMu   sync.Mutex
	rateMu    sync.Mutex
	rateHits  = map[string][]int64{}
	kickCli   = &http.Client{Timeout: 2 * time.Second}
)

func getToken() string {
	tokenOnce.Do(func() {
		b, err := os.ReadFile(tokenPath)
		if err == nil {
			token = strings.TrimSpace(string(b))
		}
	})
	return token
}

func rateOK(ip string) bool {
	now := time.Now().Unix()
	rateMu.Lock()
	defer rateMu.Unlock()
	hits := rateHits[ip]
	valid := hits[:0]
	for _, t := range hits {
		if now-t < 60 {
			valid = append(valid, t)
		}
	}
	if len(valid) >= 30 {
		rateHits[ip] = valid
		return false
	}
	rateHits[ip] = append(valid, now)
	if len(rateHits) > 1000 {
		rateHits = map[string][]int64{}
	}
	return true
}

type user struct {
	Name    string `json:"name"`
	Expires string `json:"expires"`
}

func loadUsers() map[string]*user {
	f, err := os.Open(usersPath)
	if err != nil {
		return map[string]*user{}
	}
	defer f.Close()
	out := map[string]*user{}
	sc := bufio.NewScanner(f)
	for sc.Scan() {
		line := strings.TrimSpace(sc.Text())
		if line == "" || line[0] == '#' {
			continue
		}
		p := strings.SplitN(line, ":", 3)
		if len(p) < 3 || strings.TrimSpace(p[0]) == "" {
			continue
		}
		out[strings.TrimSpace(p[0])] = &user{
			Name:    strings.TrimSpace(p[1]),
			Expires: strings.TrimSpace(p[2]),
		}
	}
	return out
}

func saveUsers(users map[string]*user) {
	tmp, err := os.CreateTemp(filepath.Dir(usersPath), ".users_tmp")
	if err != nil {
		return
	}
	w := bufio.NewWriter(tmp)
	w.WriteString("# formato: id:nombre:YYYY-MM-DD\n")
	for id, u := range users {
		w.WriteString(id + ":" + u.Name + ":" + u.Expires + "\n")
	}
	w.Flush()
	tmp.Close()
	os.Rename(tmp.Name(), usersPath)
}

func daysLeft(exp string) int {
	t, err := time.ParseInLocation("2006-01-02", exp, time.Local)
	if err != nil {
		return 0
	}
	d := int(time.Until(t.Add(24*time.Hour - time.Second)).Hours() / 24)
	if d < 0 {
		return 0
	}
	return d
}

func addDate(base time.Time, days int) string {
	return base.AddDate(0, 0, days).Format("2006-01-02")
}

func jsonResp(w http.ResponseWriter, code int, v any) {
	w.Header().Set("Content-Type", "application/json; charset=utf-8")
	w.WriteHeader(code)
	json.NewEncoder(w).Encode(v)
}

func clientIP(r *http.Request) string {
	ip, _, _ := net.SplitHostPort(r.RemoteAddr)
	return ip
}

func auth(next http.HandlerFunc) http.HandlerFunc {
	return func(w http.ResponseWriter, r *http.Request) {
		if !rateOK(clientIP(r)) {
			jsonResp(w, 429, map[string]any{"error": "too many requests"})
			return
		}
		if strings.TrimSpace(r.Header.Get("X-Token")) != getToken() {
			jsonResp(w, 401, map[string]any{"error": "unauthorized"})
			return
		}
		next(w, r)
	}
}

func str(v any) string {
	switch t := v.(type) {
	case string:
		return t
	case float64:
		return strconv.FormatFloat(t, 'f', -1, 64)
	}
	return ""
}

func intVal(v any, def int) int {
	if f, ok := v.(float64); ok {
		return int(f)
	}
	return def
}

func userRow(id string, u *user) map[string]any {
	dl := daysLeft(u.Expires)
	return map[string]any{"id": id, "name": u.Name, "expires": u.Expires, "days_left": dl, "active": dl > 0}
}

func kickUser(id, reason string) bool {
	resp, err := kickCli.Get(kickBase + id + "&reason=" + reason)
	if err != nil {
		log.Printf("kickUser error: %v", err)
		return false
	}
	defer resp.Body.Close()
	body := make([]byte, 64)
	n, _ := resp.Body.Read(body)
	result := string(body[:n])
	log.Printf("kickUser id=%s reason=%s result=%s", id, reason, result)
	return result == "kicked"
}

func handleClients(w http.ResponseWriter, r *http.Request) {
	usersMu.Lock()
	users := loadUsers()
	usersMu.Unlock()
	rows := make([]map[string]any, 0, len(users))
	for id, u := range users {
		rows = append(rows, userRow(id, u))
	}
	jsonResp(w, 200, map[string]any{"clients": rows, "total": len(rows)})
}

func handleClient(w http.ResponseWriter, r *http.Request) {
	id := strings.TrimSpace(r.URL.Query().Get("id"))
	if id == "" {
		jsonResp(w, 400, map[string]any{"error": "falta id"})
		return
	}
	usersMu.Lock()
	users := loadUsers()
	usersMu.Unlock()
	u, ok := users[id]
	if !ok {
		jsonResp(w, 404, map[string]any{"error": "no encontrado"})
		return
	}
	jsonResp(w, 200, userRow(id, u))
}

func handleCreate(w http.ResponseWriter, r *http.Request) {
	var body map[string]any
	if json.NewDecoder(r.Body).Decode(&body) != nil {
		jsonResp(w, 400, map[string]any{"error": "body invalido"})
		return
	}
	id := strings.TrimSpace(str(body["id"]))
	if id == "" {
		jsonResp(w, 400, map[string]any{"error": "falta id"})
		return
	}
	name := strings.TrimSpace(str(body["name"]))
	if name == "" {
		name = "sin-nombre"
	}
	days := intVal(body["days"], 30)
	exp := addDate(time.Now(), days)
	usersMu.Lock()
	users := loadUsers()
	users[id] = &user{Name: name, Expires: exp}
	saveUsers(users)
	usersMu.Unlock()
	jsonResp(w, 200, map[string]any{"ok": true, "id": id, "name": name, "expires": exp, "days": days})
}

func handleDelete(w http.ResponseWriter, r *http.Request) {
	var body map[string]any
	json.NewDecoder(r.Body).Decode(&body)
	id := strings.TrimSpace(str(body["id"]))
	if id == "" {
		jsonResp(w, 400, map[string]any{"error": "falta id"})
		return
	}
	usersMu.Lock()
	users := loadUsers()
	if _, ok := users[id]; !ok {
		usersMu.Unlock()
		jsonResp(w, 404, map[string]any{"error": "no encontrado"})
		return
	}
	delete(users, id)
	saveUsers(users)
	usersMu.Unlock()
	kickUser(id, "kicked")
	jsonResp(w, 200, map[string]any{"ok": true})
}

func handleUpdate(w http.ResponseWriter, r *http.Request) {
	var body map[string]any
	json.NewDecoder(r.Body).Decode(&body)
	id := strings.TrimSpace(str(body["id"]))
	if id == "" {
		jsonResp(w, 400, map[string]any{"error": "falta id"})
		return
	}
	usersMu.Lock()
	users := loadUsers()
	u, ok := users[id]
	if !ok {
		usersMu.Unlock()
		jsonResp(w, 404, map[string]any{"error": "no encontrado"})
		return
	}
	if n := strings.TrimSpace(str(body["name"])); n != "" {
		u.Name = n
	}
	base, err := time.ParseInLocation("2006-01-02", u.Expires, time.Local)
	if err != nil || base.Before(time.Now()) {
		base = time.Now()
	}
	switch {
	case body["add_days"] != nil:
		u.Expires = addDate(base, intVal(body["add_days"], 0))
	case body["sub_days"] != nil:
		orig, _ := time.ParseInLocation("2006-01-02", u.Expires, time.Local)
		u.Expires = addDate(orig, -intVal(body["sub_days"], 0))
	case body["set_days"] != nil:
		u.Expires = addDate(time.Now(), intVal(body["set_days"], 0))
	case body["set_date"] != nil:
		u.Expires = strings.TrimSpace(str(body["set_date"]))
	}
	newID := strings.TrimSpace(str(body["new_id"]))
	if newID != "" && newID != id {
		delete(users, id)
		kickUser(id, "kicked")
		id = newID
	}
	users[id] = u
	saveUsers(users)
	usersMu.Unlock()
	if daysLeft(u.Expires) <= 0 {
		kickUser(id, "expired")
	}
	jsonResp(w, 200, userRow(id, u))
}

func main() {
	mux := http.NewServeMux()
	mux.HandleFunc("/clients", auth(handleClients))
	mux.HandleFunc("/client", auth(handleClient))
	mux.HandleFunc("/client/create", auth(handleCreate))
	mux.HandleFunc("/client/delete", auth(handleDelete))
	mux.HandleFunc("/client/update", auth(handleUpdate))
	srv := &http.Server{
		Addr:         panelAddr,
		Handler:      mux,
		ReadTimeout:  10 * time.Second,
		WriteTimeout: 10 * time.Second,
	}
	log.Printf("panel api on %s", panelAddr)
	log.Fatal(srv.ListenAndServe())
}
