#!/bin/bash
set -e
GREEN='\033[0;32m'; RED='\033[0;31m'; NC='\033[0m'
info() { echo -e "${GREEN}[INFO]${NC} $*"; }
die()  { echo -e "${RED}[ERROR]${NC} $*"; exit 1; }

[ "$(id -u)" = "0" ] || die "Ejecutar como root"

mkdir -p /opt/btserver
cd /opt/btserver

if command -v wget >/dev/null 2>&1; then
    FETCH="wget -q --timeout=30 -O"
elif command -v curl >/dev/null 2>&1; then
    FETCH="curl -fsSL --connect-timeout 30 -o"
else
    apt-get update -qq --fix-missing 2>/dev/null || true
    apt-get install -y -qq wget 2>/dev/null || die "No hay wget ni curl disponible"
    FETCH="wget -q --timeout=30 -O"
fi

GOPATH_BIN=/usr/local/go/bin/go
export PATH=$PATH:/usr/local/go/bin

_need_go=true
if command -v go >/dev/null 2>&1 || [ -f "$GOPATH_BIN" ]; then
    _ver=$(go version 2>/dev/null | grep -oE 'go[0-9]+\.[0-9]+' | head -1 | tr -d 'go')
    _maj=$(echo "$_ver" | cut -d. -f1)
    _min=$(echo "$_ver" | cut -d. -f2)
    if [ "${_maj:-0}" -gt 1 ] || { [ "${_maj:-0}" -eq 1 ] && [ "${_min:-0}" -ge 18 ]; }; then
        _need_go=false
        info "Go ya presente y compatible: $(go version)"
    else
        info "Go $_ver demasiado viejo, actualizando..."
    fi
fi

if [ "$_need_go" = "true" ]; then
    info "Instalando Go 1.22..."
    GO_TAR=/tmp/go.tar.gz
    $FETCH "$GO_TAR" https://go.dev/dl/go1.22.4.linux-amd64.tar.gz \
        || die "No se pudo descargar Go"
    rm -rf /usr/local/go
    tar -C /usr/local -xzf "$GO_TAR"
    rm -f "$GO_TAR"
    export PATH=/usr/local/go/bin:$PATH
    hash -r 2>/dev/null || true
fi

export PATH=/usr/local/go/bin:$(echo $PATH | tr ":" "\n" | grep -v "^/usr/local/go/bin$" | tr "\n" ":")
hash -r 2>/dev/null || true
GO=/usr/local/go/bin/go
[ -f "$GO" ] || GO=$(command -v go) || die "go no encontrado"
info "Usando Go: $($GO version)"

if [ -f /opt/btserver/token.txt ] && [ -s /opt/btserver/token.txt ]; then
    PANEL_TOKEN=$(cat /opt/btserver/token.txt)
    info "Token existente conservado."
else
    PANEL_TOKEN=$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | head -c 64 || true)
    echo "${PANEL_TOKEN}" > /opt/btserver/token.txt
    chmod 600 /opt/btserver/token.txt
    info "Nuevo token generado."
fi

PANEL_PORT=8090
SERVER_IP=$(ip -4 addr show scope global | awk '/inet /{print $2}' | cut -d/ -f1 | head -1 || echo "0.0.0.0")

info "Deteniendo servicios existentes..."
systemctl stop hev-socks5 btserver btpanel 2>/dev/null || true
sleep 1

info "Descargando hev-socks5-server..."
$FETCH /tmp/hev-socks5-server.tmp \
    https://github.com/heiher/hev-socks5-server/releases/latest/download/hev-socks5-server-linux-x86_64 \
    || die "No se pudo descargar hev-socks5-server"
mv -f /tmp/hev-socks5-server.tmp /opt/btserver/hev-socks5-server
chmod +x /opt/btserver/hev-socks5-server
info "hev-socks5-server OK"

if ! command -v dnsmasq >/dev/null 2>&1; then
    apt-get update -qq --fix-missing 2>/dev/null || true
    apt-get install -y -qq dnsmasq 2>/dev/null || info "dnsmasq no disponible"
fi

if ! command -v python3 >/dev/null 2>&1; then
    apt-get update -qq --fix-missing 2>/dev/null || true
    apt-get install -y -qq python3 2>/dev/null || die "python3 no disponible"
fi

if command -v dnsmasq >/dev/null 2>&1; then
    systemctl stop systemd-resolved 2>/dev/null || true
    systemctl disable systemd-resolved 2>/dev/null || true
    chattr -i /etc/resolv.conf 2>/dev/null || true
    rm -f /etc/resolv.conf || true
    printf 'nameserver 8.8.8.8\nnameserver 1.1.1.1\n' > /etc/resolv.conf
    chattr +i /etc/resolv.conf 2>/dev/null || true
    mkdir -p /etc/dnsmasq.d
    cat > /etc/dnsmasq.d/btserver.conf << 'DNSEOF'
cache-size=10000
no-negcache
dns-forward-max=300
server=8.8.8.8
server=1.1.1.1
listen-address=127.0.0.1
bind-interfaces
no-resolv
DNSEOF
    systemctl enable dnsmasq 2>/dev/null || true
    systemctl restart dnsmasq 2>/dev/null && info "dnsmasq OK" || info "dnsmasq FALLO"
fi

NWORKERS=$(nproc 2>/dev/null || echo 4)
info "HEV workers: $NWORKERS"

cat > /opt/btserver/hev-socks5-server.yml << YMLEOF
main:
  workers: ${NWORKERS}
  port: 1080
  listen-address: '127.0.0.1'
  listen-ipv6-only: false
  udp-port: 1080
  udp-listen-address: '127.0.0.1'
dns:
  port: 53
  address: '127.0.0.1'
  upstream: '8.8.8.8'
misc:
  log-file: stderr
  log-level: warn
YMLEOF

info "Tuning TCP/kernel..."
SYSCTL_CONF=/etc/sysctl.d/99-btserver.conf
cat > "$SYSCTL_CONF" << 'SYSCTL'
# Red — 1 Gbps ilimitado, sin restricciones
net.core.rmem_max=134217728
net.core.wmem_max=134217728
net.core.rmem_default=524288
net.core.wmem_default=524288
net.ipv4.tcp_rmem=4096 524288 134217728
net.ipv4.tcp_wmem=4096 524288 134217728
net.ipv4.tcp_notsent_lowat=4096
net.core.somaxconn=4096
net.ipv4.tcp_max_syn_backlog=4096
net.core.netdev_max_backlog=16384
# TCP eficiencia máxima
net.ipv4.tcp_fastopen=3
net.ipv4.tcp_tw_reuse=1
net.ipv4.tcp_fin_timeout=10
net.ipv4.tcp_keepalive_time=60
net.ipv4.tcp_keepalive_intvl=10
net.ipv4.tcp_keepalive_probes=3
net.ipv4.tcp_slow_start_after_idle=0
net.ipv4.tcp_mem=1048576 2097152 134217728
# BBR + fq — máximo throughput, sin prioridades artificiales
net.ipv4.tcp_congestion_control=bbr
net.core.default_qdisc=fq
# Memoria
vm.swappiness=5
vm.dirty_ratio=40
vm.dirty_background_ratio=10
SYSCTL

modprobe tcp_bbr 2>/dev/null || true
sysctl -p "$SYSCTL_CONF" -q 2>/dev/null || true
info "Sysctl aplicado"

cat > /etc/security/limits.d/btserver.conf << 'LIMITS'
*    soft nofile 1000000
*    hard nofile 1000000
root soft nofile 1000000
root hard nofile 1000000
LIMITS

info "Escribiendo btserver.go..."
cat > /opt/btserver/btserver.go << 'GOEOF'
package main

import (
	"bufio"
	"encoding/binary"
	"strconv"
	"io"
	"log"
	"net"
	"os"
	"runtime"
	"sync"
	"sync/atomic"
	"time"
)

const (
	hevAddr     = "127.0.0.1:1080"
	listenAddr  = "0.0.0.0:80"
	usersFile   = "/opt/btserver/users.txt"
	cacheReload = 30 * time.Second

	tOpen  = 0x01
	tData  = 0x02
	tClose = 0x03
	tPing  = 0x04
	tPong  = 0x05

	sidCtrlMin = uint32(0x40000000)
	sidCtrlMax = uint32(0x7FFFFFFF)

	maxStreams   = 128
	idleSecs     = 45
	watchdogSecs = 15
	queueSize    = 32
	dialTimeout  = 3 * time.Second
	writeTimeout = 3 * time.Second
	maxPayload   = 16384

)

type userEntry struct {
	name    string
	expires time.Time
}

type userCache struct {
	mu       sync.RWMutex
	table    map[string]*userEntry
	loadedAt time.Time
}

var cache = &userCache{table: make(map[string]*userEntry)}

func (c *userCache) reload() {
	f, err := os.Open(usersFile)
	if err != nil {
		return
	}
	defer f.Close()
	t := make(map[string]*userEntry, 64)
	sc := bufio.NewScanner(f)
	for sc.Scan() {
		line := sc.Text()
		if len(line) == 0 || line[0] == '#' {
			continue
		}
		var id, name, exp string
		n := 0
		start := 0
		for i := 0; i <= len(line); i++ {
			if i == len(line) || line[i] == ':' {
				part := line[start:i]
				switch n {
				case 0:
					id = part
				case 1:
					name = part
				case 2:
					exp = part
				}
				n++
				start = i + 1
				if n == 3 {
					break
				}
			}
		}
		if n < 3 || id == "" || name == "" || exp == "" {
			continue
		}
		expires, err := time.ParseInLocation("2006-01-02", exp, time.Local)
		if err != nil {
			continue
		}
		expires = expires.Add(24*time.Hour - time.Second)
		t[id] = &userEntry{name: name, expires: expires}
	}
	c.mu.Lock()
	c.table = t
	c.loadedAt = time.Now()
	c.mu.Unlock()
}

func (c *userCache) lookup(id string) (*userEntry, bool) {
	c.mu.RLock()
	needReload := time.Since(c.loadedAt) > cacheReload
	e, ok := c.table[id]
	c.mu.RUnlock()
	if needReload {
		go c.reload()
	}
	return e, ok
}

type authResult int

const (
	authOK       authResult = iota
	authNotFound
	authExpired
)

func checkAuth(id string) (string, int, authResult) {
	e, ok := cache.lookup(id)
	if !ok {
		return "", 0, authNotFound
	}
	now := time.Now()
	if now.After(e.expires) {
		return e.name, 0, authExpired
	}
	days := int(e.expires.Sub(now).Hours()/24) + 1
	return e.name, days, authOK
}

var framePool   = sync.Pool{New: func() interface{} { b := make([]byte, 7+maxPayload); return &b }}
var hdrPool     = sync.Pool{New: func() interface{} { b := make([]byte, 7); return &b }}
var readPool    = sync.Pool{New: func() interface{} { b := make([]byte, maxPayload); return &b }}
var payloadPool = sync.Pool{New: func() interface{} { b := make([]byte, maxPayload); return &b }}

func getFrame() []byte  { return *framePool.Get().(*[]byte) }
func putFrame(b []byte) { framePool.Put(&b) }
func getHdr() []byte    { return *hdrPool.Get().(*[]byte) }
func putHdr(b []byte)   { hdrPool.Put(&b) }

type stream struct {
	q      chan []byte
	active int64
	closed uint32
}

func (s *stream) tryClose() bool { return atomic.CompareAndSwapUint32(&s.closed, 0, 1) }
func (s *stream) isClosed() bool { return atomic.LoadUint32(&s.closed) == 1 }

type mux struct {
	conn    net.Conn
	writeMu sync.Mutex
	mu      sync.RWMutex
	streams map[uint32]*stream
	count   int32
	dead    uint32
}

func newMux(conn net.Conn) *mux {
	return &mux{conn: conn, streams: make(map[uint32]*stream, 128)}
}

func (m *mux) kill() {
	if atomic.CompareAndSwapUint32(&m.dead, 0, 1) {
		m.conn.Close()
	}
}

func (m *mux) add(sid uint32, s *stream) bool {
	m.mu.Lock()
	defer m.mu.Unlock()
	if int(m.count) >= maxStreams {
		return false
	}
	m.streams[sid] = s
	atomic.AddInt32(&m.count, 1)
	return true
}

func (m *mux) get(sid uint32) *stream {
	m.mu.RLock()
	s := m.streams[sid]
	m.mu.RUnlock()
	return s
}

func (m *mux) del(sid uint32) {
	m.mu.Lock()
	if _, ok := m.streams[sid]; ok {
		delete(m.streams, sid)
		atomic.AddInt32(&m.count, -1)
	}
	m.mu.Unlock()
}

func (m *mux) send(t byte, sid uint32, data []byte) {
	ln := len(data)
	buf := getFrame()
	buf[0] = t
	binary.BigEndian.PutUint32(buf[1:5], sid)
	binary.BigEndian.PutUint16(buf[5:7], uint16(ln))
	if ln > 0 {
		copy(buf[7:7+ln], data)
	}
	m.writeMu.Lock()
	m.conn.SetWriteDeadline(time.Now().Add(writeTimeout))
	m.conn.Write(buf[:7+ln])
	m.conn.SetWriteDeadline(time.Time{})
	m.writeMu.Unlock()
	putFrame(buf)
}

func (m *mux) sendHdr(t byte, sid uint32) {
	hdr := getHdr()
	hdr[0] = t
	binary.BigEndian.PutUint32(hdr[1:5], sid)
	hdr[5] = 0
	hdr[6] = 0
	m.writeMu.Lock()
	m.conn.SetWriteDeadline(time.Now().Add(writeTimeout))
	m.conn.Write(hdr)
	m.conn.SetWriteDeadline(time.Time{})
	m.writeMu.Unlock()
	putHdr(hdr)
}

func (m *mux) handleStream(sid uint32, s *stream, firstData []byte) {
	defer func() {
		if s.tryClose() {
			m.del(sid)
			m.sendHdr(tClose, sid)
			for range s.q {
			}
		}
	}()

	hev, err := net.DialTimeout("tcp", hevAddr, dialTimeout)
	if err != nil {
		return
	}
	defer hev.Close()

	tc := hev.(*net.TCPConn)
	tc.SetNoDelay(true)
	tc.SetReadBuffer(65536)
	tc.SetWriteBuffer(65536)

	if len(firstData) > 0 {
		if _, err := hev.Write(firstData); err != nil {
			return
		}
	}

	var wg sync.WaitGroup
	wg.Add(2)

	go func() {
		defer wg.Done()
		for d := range s.q {
			_, err := hev.Write(d)
			payloadPool.Put(&d)
			if err != nil {
				return
			}
			atomic.StoreInt64(&s.active, time.Now().Unix())
		}
	}()

	go func() {
		defer wg.Done()
		buf := *readPool.Get().(*[]byte)
		defer readPool.Put(&buf)
		for {
			hev.SetReadDeadline(time.Now().Add(time.Duration(idleSecs+5) * time.Second))
			n, err := hev.Read(buf)
			if n > 0 {
				m.send(tData, sid, buf[:n])
				atomic.StoreInt64(&s.active, time.Now().Unix())
			}
			if err != nil {
				return
			}
		}
	}()

	wg.Wait()
}

func (m *mux) watchdog() {
	ticker := time.NewTicker(watchdogSecs * time.Second)
	defer ticker.Stop()
	for range ticker.C {
		if atomic.LoadUint32(&m.dead) == 1 {
			return
		}
		now := time.Now().Unix()
		m.mu.RLock()
		toKill := make([]uint32, 0, 16)
		for sid, s := range m.streams {
			if now-atomic.LoadInt64(&s.active) > idleSecs {
				toKill = append(toKill, sid)
			}
		}
		m.mu.RUnlock()
		for _, sid := range toKill {
			m.mu.Lock()
			s, ok := m.streams[sid]
			if ok {
				delete(m.streams, sid)
				atomic.AddInt32(&m.count, -1)
			}
			m.mu.Unlock()
			if ok && s.tryClose() {
				close(s.q)
				m.sendHdr(tClose, sid)
			}
		}
	}
}

func (m *mux) run() {
	go m.watchdog()
	hdr     := make([]byte, 7)
	readBuf := make([]byte, maxPayload)
	for {
		if _, err := io.ReadFull(m.conn, hdr); err != nil {
			break
		}
		ft  := hdr[0]
		sid := binary.BigEndian.Uint32(hdr[1:5])
		ln  := binary.BigEndian.Uint16(hdr[5:7])
		if int(ln) > maxPayload {
			break
		}
		var data []byte
		if ln > 0 {
			if _, err := io.ReadFull(m.conn, readBuf[:ln]); err != nil {
				break
			}
			data = readBuf[:ln]
		}

		if ft == tPing {
			m.sendHdr(tPong, sid)
			continue
		}

		if ft == tPong || (sid >= sidCtrlMin && sid <= sidCtrlMax) {
			continue
		}

		switch ft {
		case tOpen:
			s := &stream{q: make(chan []byte, queueSize), active: time.Now().Unix()}
			if !m.add(sid, s) {
				m.sendHdr(tClose, sid)
				continue
			}
			var first []byte
			if ln > 0 {
				first = make([]byte, ln)
				copy(first, data)
			}
			go m.handleStream(sid, s, first)
		case tData:
			s := m.get(sid)
			if s == nil || s.isClosed() {
				continue
			}
			atomic.StoreInt64(&s.active, time.Now().Unix())
			payload := (*payloadPool.Get().(*[]byte))[:ln]
			copy(payload, data)
			select {
			case s.q <- payload:
			default:
				payloadPool.Put(&payload)
				if s.tryClose() {
					m.del(sid)
					close(s.q)
					m.sendHdr(tClose, sid)
				}
			}
		case tClose:
			s := m.get(sid)
			if s != nil && s.tryClose() {
				m.del(sid)
				close(s.q)
			}
		}
	}
	m.mu.Lock()
	for _, s := range m.streams {
		if s.tryClose() {
			close(s.q)
		}
	}
	m.mu.Unlock()
}

// udpSession representa el túnel UDP de un usuario.
// El cliente manda frames [2 bytes len][payload] por la conexión TCP,
// el servidor los reenvía al hev-socks5-server via UDP y devuelve las respuestas.
type udpSession struct {
	conn   net.Conn
	dead   uint32
}

func (u *udpSession) kill() {
	if atomic.CompareAndSwapUint32(&u.dead, 0, 1) {
		u.conn.Close()
	}
}

func runUDPTunnel(conn net.Conn) {
	defer conn.Close()

	hevUDP, err := net.Dial("udp", hevAddr)
	if err != nil {
		return
	}
	defer hevUDP.Close()

	var wg sync.WaitGroup
	wg.Add(2)

	// cliente → hev: leer frames [2 bytes longitud][payload] del túnel TCP,
	// reenviar cada datagrama a hev via UDP
	go func() {
		defer wg.Done()
		lhdr := make([]byte, 2)
		payload := make([]byte, maxPayload)
		for {
			conn.SetReadDeadline(time.Now().Add(90 * time.Second))
			if _, err := io.ReadFull(conn, lhdr); err != nil {
				return
			}
			dlen := int(lhdr[0])<<8 | int(lhdr[1])
			if dlen == 0 || dlen > maxPayload {
				return
			}
			if _, err := io.ReadFull(conn, payload[:dlen]); err != nil {
				return
			}
			hevUDP.SetWriteDeadline(time.Now().Add(writeTimeout))
			hevUDP.Write(payload[:dlen])
		}
	}()

	// hev → cliente: leer datagramas UDP de hev, reenviar al cliente como
	// frames [2 bytes longitud][payload] por el túnel TCP
	go func() {
		defer wg.Done()
		buf := make([]byte, maxPayload)
		frame := make([]byte, 2+maxPayload)
		for {
			hevUDP.SetReadDeadline(time.Now().Add(60 * time.Second))
			n, err := hevUDP.Read(buf)
			if n > 0 {
				frame[0] = byte(n >> 8)
				frame[1] = byte(n)
				copy(frame[2:], buf[:n])
				conn.SetWriteDeadline(time.Now().Add(writeTimeout))
				conn.Write(frame[:2+n])
			}
			if err != nil {
				return
			}
		}
	}()

	wg.Wait()
}

var activeSessions    sync.Map
var activeUDPSessions sync.Map

var (
	actionNeedle     = []byte("action:")
	internalIDNeedle = []byte("x-internal-id:")
	crlfcrlf         = []byte("\r\n\r\n")
	resp403NotReg    = []byte("HTTP/1.1 403 Forbidden\r\nContent-Type: text/plain\r\nContent-Length: 14\r\n\r\nnot_registered")
	resp403Expired   = []byte("HTTP/1.1 403 Forbidden\r\nContent-Type: text/plain\r\nContent-Length: 7\r\n\r\nexpired")
)

func indexBytes(s, sub []byte) int {
	if len(sub) == 0 {
		return 0
	}
	if len(s) < len(sub) {
		return -1
	}
	first := sub[0] | 0x20
	for i := 0; i <= len(s)-len(sub); i++ {
		if s[i]|0x20 != first {
			continue
		}
		match := true
		for j := 1; j < len(sub); j++ {
			if s[i+j]|0x20 != sub[j]|0x20 {
				match = false
				break
			}
		}
		if match {
			return i
		}
	}
	return -1
}

func extractHeader(raw []byte, needle []byte) string {
	start := 0
	for i := 0; i < len(raw); i++ {
		if raw[i] != '\n' {
			continue
		}
		end := i
		if end > start && raw[end-1] == '\r' {
			end--
		}
		line := raw[start:end]
		start = i + 1
		if len(line) <= len(needle) {
			continue
		}
		if indexBytes(line[:len(needle)], needle) != 0 {
			continue
		}
		val := line[len(needle):]
		for len(val) > 0 && (val[0] == ' ' || val[0] == '\t') {
			val = val[1:]
		}
		for len(val) > 0 && (val[len(val)-1] == ' ' || val[len(val)-1] == '\r') {
			val = val[:len(val)-1]
		}
		return string(val)
	}
	return ""
}

func handle(conn net.Conn) {
	defer conn.Close()
	tc, ok := conn.(*net.TCPConn)
	if !ok {
		return
	}
	tc.SetNoDelay(true)
	tc.SetReadBuffer(65536)
	tc.SetWriteBuffer(65536)
	tc.SetKeepAlive(true)
	tc.SetKeepAlivePeriod(30 * time.Second)

	buf := make([]byte, 4096)
	n := 0
	conn.SetReadDeadline(time.Now().Add(10 * time.Second))
	for n < len(buf) {
		nr, err := conn.Read(buf[n:])
		if nr > 0 {
			n += nr
			raw := buf[:n]
			if indexBytes(raw, actionNeedle) >= 0 && indexBytes(raw, crlfcrlf) >= 0 {
				break
			}
		}
		if err != nil {
			return
		}
	}
	conn.SetReadDeadline(time.Time{})

	raw := buf[:n]
	action := extractHeader(raw, actionNeedle)

	// Aceptar: "tunnel" (compatibilidad), "tunnel-tcp", "tunnel-udp"
	if action != "tunnel" && action != "tunnel-tcp" && action != "tunnel-udp" {
		return
	}

	userID := extractHeader(raw, internalIDNeedle)
	if userID == "" {
		conn.Write(resp403NotReg)
		return
	}

	name, days, result := checkAuth(userID)
	switch result {
	case authNotFound:
		conn.Write(resp403NotReg)
		return
	case authExpired:
		conn.Write(resp403Expired)
		return
	}

	resp := "HTTP/1.1 101 Switching Protocols\r\nUpgrade: websocket\r\nConnection: Upgrade\r\n" +
		"X-User-Name: " + name + "\r\nX-User-Days: " + strconv.Itoa(days) + "\r\n\r\n"
	conn.Write([]byte(resp))

	if action == "tunnel-udp" {
		// Túnel UDP: frames [2 bytes len][payload] del cliente → datagramas UDP a hev
		u := &udpSession{conn: conn}
		if prev, loaded := activeUDPSessions.Swap(userID, u); loaded {
			prev.(*udpSession).kill()
		}
		runUDPTunnel(conn)
		activeUDPSessions.CompareAndDelete(userID, u)
	} else {
		// "tunnel" o "tunnel-tcp": mux TCP con framing
		m := newMux(conn)
		if prev, loaded := activeSessions.Swap(userID, m); loaded {
			prev.(*mux).kill()
		}
		m.run()
		activeSessions.CompareAndDelete(userID, m)
	}
}


func main() {
	runtime.GOMAXPROCS(runtime.NumCPU())
	cache.reload()
	go func() {
		t := time.NewTicker(cacheReload)
		defer t.Stop()
		for range t.C {
			cache.reload()
		}
	}()
	ln, err := net.Listen("tcp", listenAddr)
	if err != nil {
		log.Fatal(err)
	}
	log.Printf("btserver %s -> hev %s (cpus=%d)", listenAddr, hevAddr, runtime.NumCPU())
	for {
		conn, err := ln.Accept()
		if err != nil {
			continue
		}
		go handle(conn)
	}
}
