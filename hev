#!/bin/bash
set -e
GREEN='\033[0;32m'; RED='\033[0;31m'; NC='\033[0m'
info() { echo -e "${GREEN}[INFO]${NC} $*"; }
die()  { echo -e "${RED}[ERROR]${NC} $*"; exit 1; }

[ "$(id -u)" = "0" ] || die "Ejecutar como root"

mkdir -p /opt/btserver
cd /opt/btserver

if command -v wget >/dev/null 2>&1; then
    FETCH="wget -q --timeout=30 -O"
elif command -v curl >/dev/null 2>&1; then
    FETCH="curl -fsSL --connect-timeout 30 -o"
else
    apt-get update -qq --fix-missing 2>/dev/null || true
    apt-get install -y -qq wget 2>/dev/null || die "No hay wget ni curl"
    FETCH="wget -q --timeout=30 -O"
fi

info "Instalando Go..."
rm -rf /usr/local/go
$FETCH /tmp/go.tar.gz https://go.dev/dl/go1.22.3.linux-amd64.tar.gz || die "No se pudo descargar Go"
tar -C /usr/local -xzf /tmp/go.tar.gz
rm -f /tmp/go.tar.gz
ln -sf /usr/local/go/bin/go /usr/local/bin/go
ln -sf /usr/local/go/bin/gofmt /usr/local/bin/gofmt
export PATH=/usr/local/go/bin:$PATH
GO=/usr/local/go/bin/go
info "Go: $($GO version)"

if [ -f /opt/btserver/token.txt ] && [ -s /opt/btserver/token.txt ]; then
    PANEL_TOKEN=$(cat /opt/btserver/token.txt)
    info "Token existente conservado."
else
    PANEL_TOKEN=$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | head -c 64 || true)
    echo "${PANEL_TOKEN}" > /opt/btserver/token.txt
    chmod 600 /opt/btserver/token.txt
    info "Nuevo token generado."
fi

PANEL_PORT=8090
SERVER_IP=$(ip -4 addr show scope global | awk '/inet /{print $2}' | cut -d/ -f1 | head -1 || echo "0.0.0.0")

info "Deteniendo servicios..."
systemctl stop hev-socks5 btserver btpanel 2>/dev/null || true
sleep 1

info "Descargando hev-socks5-server..."
$FETCH /tmp/hev-socks5-server.tmp \
    https://github.com/heiher/hev-socks5-server/releases/latest/download/hev-socks5-server-linux-x86_64 \
    || die "No se pudo descargar hev-socks5-server"
mv -f /tmp/hev-socks5-server.tmp /opt/btserver/hev-socks5-server
chmod +x /opt/btserver/hev-socks5-server
info "hev-socks5-server OK"

NWORKERS=$(nproc 2>/dev/null || echo 1)
info "HEV workers: $NWORKERS"

cat > /opt/btserver/hev-socks5-server.yml << YMLEOF
main:
  workers: ${NWORKERS}
  port: 1080
  listen-address: '127.0.0.1'
  listen-ipv6-only: false
  udp-port: 1080
  udp-listen-address: '127.0.0.1'
  domain-address-type: ipv4
dns:
  port: 53
  address: '127.0.0.1'
  upstream: '8.8.8.8'
misc:
  connect-timeout: 5000
  read-write-timeout: 300000
  log-file: stderr
  log-level: warn
YMLEOF

info "Tuning TCP/kernel..."
cat > /etc/sysctl.d/99-btserver.conf << 'SYSCTL'
net.core.rmem_max=33554432
net.core.wmem_max=33554432
net.core.rmem_default=262144
net.core.wmem_default=262144
net.ipv4.tcp_rmem=4096 262144 33554432
net.ipv4.tcp_wmem=4096 262144 33554432
net.ipv4.tcp_notsent_lowat=4096
net.ipv4.tcp_fastopen=3
net.ipv4.tcp_tw_reuse=1
net.ipv4.tcp_fin_timeout=10
net.ipv4.tcp_keepalive_time=60
net.ipv4.tcp_keepalive_intvl=10
net.ipv4.tcp_keepalive_probes=3
net.core.somaxconn=65535
net.ipv4.tcp_max_syn_backlog=65535
net.core.netdev_max_backlog=65535
fs.file-max=1000000
net.ipv4.tcp_mem=786432 1048576 33554432
net.ipv4.tcp_congestion_control=bbr
net.core.default_qdisc=fq
net.ipv4.tcp_slow_start_after_idle=0
net.ipv4.tcp_mtu_probing=1
net.ipv4.ip_local_port_range=1024 65535
net.ipv4.tcp_max_tw_buckets=2000000
SYSCTL
modprobe tcp_bbr 2>/dev/null || true
sysctl -p /etc/sysctl.d/99-btserver.conf -q 2>/dev/null || true
info "Sysctl aplicado"

cat > /etc/security/limits.d/btserver.conf << 'LIMITS'
*    soft nofile 1000000
*    hard nofile 1000000
root soft nofile 1000000
root hard nofile 1000000
LIMITS

# ── btserver.go ───────────────────────────────────────────────────
info "Escribiendo btserver.go..."
cat > /opt/btserver/btserver.go << 'GOEOF'
//go:build go1.20

package main

import (
	"bufio"
	"encoding/binary"
	"io"
	"log"
	"net"
	"os"
	"runtime"
	"runtime/debug"
	"sync"
	"sync/atomic"
	"syscall"
	"time"
)

const (
	hevTCPAddr  = "127.0.0.1:1080"
	hevUDPAddr  = "127.0.0.1:1080"
	listenAddr  = "0.0.0.0:80"
	usersFile   = "/opt/btserver/users.txt"
	cacheReload = 30 * time.Second

	tOpen  byte = 0x01
	tData  byte = 0x02
	tClose byte = 0x03
	tPing  byte = 0x04
	tPong  byte = 0x05

	maxStreams   = 8192
	queueSize    = 64
	dialTimeout  = 100 * time.Millisecond
	writeTimeout = 5 * time.Second
	maxPayload   = 16384
)

/* ── Usuarios ─────────────────────────────────────────────────── */

type userEntry struct {
	name    string
	expires time.Time
}

type userCache struct {
	mu       sync.RWMutex
	table    map[string]*userEntry
	loadedAt time.Time
}

var cache = &userCache{table: make(map[string]*userEntry)}

func (c *userCache) reload() {
	f, err := os.Open(usersFile)
	if err != nil {
		return
	}
	defer f.Close()
	t := make(map[string]*userEntry, 64)
	sc := bufio.NewScanner(f)
	for sc.Scan() {
		line := sc.Text()
		if len(line) == 0 || line[0] == '#' {
			continue
		}
		var id, name, exp string
		n, start := 0, 0
		for i := 0; i <= len(line); i++ {
			if i == len(line) || line[i] == ':' {
				switch n {
				case 0:
					id = line[start:i]
				case 1:
					name = line[start:i]
				case 2:
					exp = line[start:i]
				}
				n++
				start = i + 1
				if n == 3 {
					break
				}
			}
		}
		if n < 3 || id == "" || name == "" || exp == "" {
			continue
		}
		expires, err := time.ParseInLocation("2006-01-02", exp, time.Local)
		if err != nil {
			continue
		}
		expires = expires.Add(24*time.Hour - time.Second)
		t[id] = &userEntry{name: name, expires: expires}
	}
	c.mu.Lock()
	c.table = t
	c.loadedAt = time.Now()
	c.mu.Unlock()
}

func (c *userCache) lookup(id string) (*userEntry, bool) {
	c.mu.RLock()
	needReload := time.Since(c.loadedAt) > cacheReload
	e, ok := c.table[id]
	c.mu.RUnlock()
	if needReload {
		go c.reload()
	}
	return e, ok
}

type authResult int

const (
	authOK       authResult = iota
	authNotFound
	authExpired
)

func checkAuth(id string) (string, int, authResult) {
	e, ok := cache.lookup(id)
	if !ok {
		return "", 0, authNotFound
	}
	if time.Now().After(e.expires) {
		return e.name, 0, authExpired
	}
	days := int(e.expires.Sub(time.Now()).Hours()/24) + 1
	return e.name, days, authOK
}

/* ── Frame pool ───────────────────────────────────────────────── */

var framePool = sync.Pool{New: func() interface{} {
	b := make([]byte, 7+maxPayload)
	return &b
}}

func getFrame() []byte  { return *framePool.Get().(*[]byte) }
func putFrame(b []byte) { framePool.Put(&b) }

// Pool de payloads — elimina alloca por frame en tData/tOpen
var payloadPool = sync.Pool{New: func() interface{} {
	b := make([]byte, maxPayload)
	return &b
}}

func getPayload() []byte  { return *payloadPool.Get().(*[]byte) }
func putPayload(b []byte) { payloadPool.Put(&b) }

// Pool de buffers de lectura — elimina alloca por stream en handleStream
var readBufPool = sync.Pool{New: func() interface{} {
	b := make([]byte, maxPayload)
	return &b
}}

/* ── Stream ───────────────────────────────────────────────────── */

type stream struct {
	q      chan []byte
	closed atomic.Uint32
}

func (s *stream) tryClose() bool { return s.closed.CompareAndSwap(0, 1) }
func (s *stream) isClosed() bool { return s.closed.Load() == 1 }

/* ── Mux ──────────────────────────────────────────────────────── */

type mux struct {
	conn    net.Conn
	writeQ  chan []byte
	mu      sync.RWMutex
	streams map[uint32]*stream
	count   atomic.Int32
	dead    atomic.Uint32
}

func newMux(conn net.Conn) *mux {
	m := &mux{
		conn:    conn,
		writeQ:  make(chan []byte, 4096),
		streams: make(map[uint32]*stream, 512),
	}
	go m.writeLoop()
	return m
}

func (m *mux) writeLoop() {
	var bufs net.Buffers
	var toFree [][]byte
	for buf := range m.writeQ {
		if m.dead.Load() == 1 {
			putFrame(buf[:cap(buf)])
			continue
		}
		// Acumular todo lo disponible en el canal ahora mismo
		bufs = append(bufs[:0], buf)
		toFree = append(toFree[:0], buf)
	drain:
		for {
			select {
			case b := <-m.writeQ:
				bufs = append(bufs, b)
				toFree = append(toFree, b)
			default:
				break drain
			}
		}
		m.conn.SetWriteDeadline(time.Now().Add(writeTimeout))
		bufs.WriteTo(m.conn)
		m.conn.SetWriteDeadline(time.Time{})
		for _, b := range toFree {
			putFrame(b[:cap(b)])
		}
	}
}

func (m *mux) kill() {
	if m.dead.CompareAndSwap(0, 1) {
		m.conn.Close()
		close(m.writeQ)
	}
}

func (m *mux) add(sid uint32, s *stream) bool {
	m.mu.Lock()
	defer m.mu.Unlock()
	if int(m.count.Load()) >= maxStreams {
		return false
	}
	m.streams[sid] = s
	m.count.Add(1)
	return true
}

func (m *mux) get(sid uint32) *stream {
	m.mu.RLock()
	s := m.streams[sid]
	m.mu.RUnlock()
	return s
}

func (m *mux) del(sid uint32) {
	m.mu.Lock()
	if _, ok := m.streams[sid]; ok {
		delete(m.streams, sid)
		m.count.Add(-1)
	}
	m.mu.Unlock()
}

func (m *mux) send(t byte, sid uint32, data []byte) {
	if m.dead.Load() == 1 {
		return
	}
	ln := len(data)
	buf := getFrame()
	buf[0] = t
	binary.BigEndian.PutUint32(buf[1:5], sid)
	binary.BigEndian.PutUint16(buf[5:7], uint16(ln))
	if ln > 0 {
		copy(buf[7:7+ln], data)
	}
	select {
	case m.writeQ <- buf[:7+ln]:
	default:
		putFrame(buf)
	}
}

func (m *mux) sendHdr(t byte, sid uint32) {
	if m.dead.Load() == 1 {
		return
	}
	buf := getFrame()
	buf[0] = t
	binary.BigEndian.PutUint32(buf[1:5], sid)
	buf[5] = 0
	buf[6] = 0
	select {
	case m.writeQ <- buf[:7]:
	default:
		putFrame(buf)
	}
}

/* ── handleStream — transporte puro hacia hev ────────────────── */

func (m *mux) handleStream(sid uint32, s *stream, firstData []byte) {
	defer func() {
		if s.tryClose() {
			m.del(sid)
			m.sendHdr(tClose, sid)
			for range s.q {
			}
		}
	}()

	// Siempre al motor — sin DNS propio, sin bypass
	hev, err := net.DialTimeout("tcp", hevTCPAddr, dialTimeout)
	if err != nil {
		return
	}
	defer hev.Close()

	tc := hev.(*net.TCPConn)
	tc.SetNoDelay(true)
	tc.SetReadBuffer(262144)
	tc.SetWriteBuffer(262144)

	if len(firstData) > 0 {
		if _, err := hev.Write(firstData); err != nil {
			return
		}
	}

	var wg sync.WaitGroup
	wg.Add(2)

	// Cliente → hev
	go func() {
		defer wg.Done()
		for d := range s.q {
			_, err := hev.Write(d)
			putPayload(d[:cap(d)])
			if err != nil {
				break
			}
		}
		tc.CloseWrite()
	}()

	// hev → cliente
	go func() {
		defer wg.Done()
		buf := *readBufPool.Get().(*[]byte)
		defer readBufPool.Put(&buf)
		for {
			n, err := hev.Read(buf)
			if n > 0 {
				m.send(tData, sid, buf[:n])
			}
			if err != nil {
				return
			}
		}
	}()

	wg.Wait()
}

/* ── Mux loop — lee frames del cliente ───────────────────────── */

func (m *mux) run() {
	hdr     := make([]byte, 7)
	readBuf := make([]byte, maxPayload)
	for {
		if _, err := io.ReadFull(m.conn, hdr); err != nil {
			break
		}
		ft  := hdr[0]
		sid := binary.BigEndian.Uint32(hdr[1:5])
		ln  := binary.BigEndian.Uint16(hdr[5:7])
		if int(ln) > maxPayload {
			break
		}
		var data []byte
		if ln > 0 {
			if _, err := io.ReadFull(m.conn, readBuf[:ln]); err != nil {
				break
			}
			data = readBuf[:ln]
		}

		if ft == tPing {
			m.sendHdr(tPong, sid)
			continue
		}
		if ft == tPong {
			continue
		}

		switch ft {
		case tOpen:
			s := &stream{q: make(chan []byte, queueSize)}
			if !m.add(sid, s) {
				m.sendHdr(tClose, sid)
				continue
			}
			var first []byte
			if ln > 0 {
				first = make([]byte, ln)
				copy(first, data)
			}
			go m.handleStream(sid, s, first)
		case tData:
			s := m.get(sid)
			if s == nil || s.isClosed() {
				continue
			}
			payload := getPayload()[:ln]
			copy(payload, data)
			select {
			case s.q <- payload:
			default:
				putPayload(payload[:cap(payload)])
				if s.tryClose() {
					m.del(sid)
					close(s.q)
					m.sendHdr(tClose, sid)
				}
			}
		case tClose:
			s := m.get(sid)
			if s != nil && s.tryClose() {
				m.del(sid)
				close(s.q)
			}
		}
	}
	m.mu.Lock()
	for _, s := range m.streams {
		if s.tryClose() {
			close(s.q)
		}
	}
	m.mu.Unlock()
}

/* ── UDP tunnel ───────────────────────────────────────────────── */

type udpSession struct {
	conn net.Conn
	dead atomic.Uint32
}

func (u *udpSession) kill() {
	if u.dead.CompareAndSwap(0, 1) {
		u.conn.Close()
	}
}

func runUDPTunnel(conn net.Conn) {
	defer conn.Close()
	hevUDP, err := net.Dial("udp", hevUDPAddr)
	if err != nil {
		return
	}
	defer hevUDP.Close()

	var wg sync.WaitGroup
	wg.Add(2)

	go func() {
		defer wg.Done()
		buf := make([]byte, maxPayload)
		for {
			n, err := conn.Read(buf)
			if n > 0 {
				hevUDP.SetWriteDeadline(time.Now().Add(writeTimeout))
				hevUDP.Write(buf[:n])
			}
			if err != nil {
				return
			}
		}
	}()

	go func() {
		defer wg.Done()
		buf := make([]byte, maxPayload)
		for {
			hevUDP.SetReadDeadline(time.Now().Add(60 * time.Second))
			n, err := hevUDP.Read(buf)
			if n > 0 {
				conn.SetWriteDeadline(time.Now().Add(writeTimeout))
				conn.Write(buf[:n])
			}
			if err != nil {
				return
			}
		}
	}()

	wg.Wait()
}

/* ── Sesiones activas ─────────────────────────────────────────── */

var activeSessions    sync.Map
var activeUDPSessions sync.Map

/* ── Handshake HTTP + auth ────────────────────────────────────── */

var (
	actionNeedle     = []byte("action:")
	internalIDNeedle = []byte("x-internal-id:")
	crlfcrlf         = []byte("

")
	resp403NotReg    = []byte("HTTP/1.1 403 Forbidden
Content-Type: text/plain
Content-Length: 14

not_registered")
	resp403Expired   = []byte("HTTP/1.1 403 Forbidden
Content-Type: text/plain
Content-Length: 7

expired")
)

func indexBytes(s, sub []byte) int {
	if len(sub) == 0 || len(s) < len(sub) {
		return -1
	}
	first := sub[0] | 0x20
	for i := 0; i <= len(s)-len(sub); i++ {
		if s[i]|0x20 != first {
			continue
		}
		match := true
		for j := 1; j < len(sub); j++ {
			if s[i+j]|0x20 != sub[j]|0x20 {
				match = false
				break
			}
		}
		if match {
			return i
		}
	}
	return -1
}

func extractHeader(raw []byte, needle []byte) string {
	start := 0
	for i := 0; i < len(raw); i++ {
		if raw[i] != '
' {
			continue
		}
		end := i
		if end > start && raw[end-1] == '
' {
			end--
		}
		line := raw[start:end]
		start = i + 1
		if len(line) <= len(needle) {
			continue
		}
		if indexBytes(line[:len(needle)], needle) != 0 {
			continue
		}
		val := line[len(needle):]
		for len(val) > 0 && (val[0] == ' ' || val[0] == '	') {
			val = val[1:]
		}
		for len(val) > 0 && (val[len(val)-1] == ' ' || val[len(val)-1] == '
') {
			val = val[:len(val)-1]
		}
		return string(val)
	}
	return ""
}

func handle(conn net.Conn) {
	defer conn.Close()
	tc, ok := conn.(*net.TCPConn)
	if !ok {
		return
	}
	tc.SetNoDelay(true)
	tc.SetReadBuffer(262144)
	tc.SetWriteBuffer(262144)
	tc.SetKeepAlive(true)
	tc.SetKeepAlivePeriod(30 * time.Second)

	buf := make([]byte, 4096)
	n := 0
	conn.SetReadDeadline(time.Now().Add(10 * time.Second))
	for n < len(buf) {
		nr, err := conn.Read(buf[n:])
		if nr > 0 {
			n += nr
			raw := buf[:n]
			if indexBytes(raw, actionNeedle) >= 0 && indexBytes(raw, crlfcrlf) >= 0 {
				break
			}
		}
		if err != nil {
			return
		}
	}
	conn.SetReadDeadline(time.Time{})

	raw := buf[:n]
	action := extractHeader(raw, actionNeedle)
	if action != "tunnel" && action != "tunnel-tcp" && action != "tunnel-udp" {
		return
	}

	userID := extractHeader(raw, internalIDNeedle)
	if userID == "" {
		conn.Write(resp403NotReg)
		return
	}

	name, days, result := checkAuth(userID)
	switch result {
	case authNotFound:
		conn.Write(resp403NotReg)
		return
	case authExpired:
		conn.Write(resp403Expired)
		return
	}

	conn.Write([]byte("HTTP/1.1 101 Switching Protocols
Upgrade: websocket
Connection: Upgrade
X-User-Name: " +
		name + "
X-User-Days: " + itoa(days) + "

"))

	if action == "tunnel-udp" {
		u := &udpSession{conn: conn}
		if prev, loaded := activeUDPSessions.Swap(userID, u); loaded {
			prev.(*udpSession).kill()
		}
		runUDPTunnel(conn)
		activeUDPSessions.CompareAndDelete(userID, u)
	} else {
		m := newMux(conn)
		if prev, loaded := activeSessions.Swap(userID, m); loaded {
			prev.(*mux).kill()
		}
		m.run()
		activeSessions.CompareAndDelete(userID, m)
	}
}

func itoa(n int) string {
	if n == 0 {
		return "0"
	}
	buf := make([]byte, 20)
	i := len(buf)
	for n > 0 {
		i--
		buf[i] = byte('0' + n%10)
		n /= 10
	}
	return string(buf[i:])
}

/* ── Main ─────────────────────────────────────────────────────── */

func main() {
	runtime.GOMAXPROCS(runtime.NumCPU())
	debug.SetMemoryLimit(768 << 20)
	cache.reload()
	go func() {
		t := time.NewTicker(cacheReload)
		defer t.Stop()
		for range t.C {
			cache.reload()
		}
	}()

	ln, err := net.Listen("tcp", listenAddr)
	if err != nil {
		log.Fatal(err)
	}
	if tc, ok := ln.(*net.TCPListener); ok {
		if raw, err := tc.SyscallConn(); err == nil {
			raw.Control(func(fd uintptr) {
				syscall.SetsockoptInt(int(fd), syscall.IPPROTO_TCP, syscall.TCP_NODELAY, 1)
				syscall.SetsockoptInt(int(fd), syscall.SOL_SOCKET, syscall.SO_REUSEADDR, 1)
				syscall.SetsockoptInt(int(fd), syscall.SOL_SOCKET, 15, 1)
			})
		}
	}

	log.Printf("btserver %s -> hev %s (go=%s cpus=%d)",
		listenAddr, hevTCPAddr, runtime.Version(), runtime.NumCPU())
	for {
		conn, err := ln.Accept()
		if err != nil {
			continue
		}
		go handle(conn)
	}
}

GOEOF

