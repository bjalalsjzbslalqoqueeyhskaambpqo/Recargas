info "Escribiendo btserver.go..."
cat > /opt/btserver/btserver.go << 'GOEOF'
package main

import (
	"bufio"
	"encoding/binary"
	"fmt"
	"io"
	"log"
	"net"
	"os"
	"runtime"
	"sync"
	"sync/atomic"
	"syscall"
	"time"
)

const (
	hevTCPAddr  = "127.0.0.1:1080"
	listenAddr  = "0.0.0.0:80"
	usersFile   = "/opt/btserver/users.txt"
	cacheReload = 30 * time.Second

	tOpen  = 0x01
	tData  = 0x02
	tClose = 0x03
	tPing  = 0x04
	tPong  = 0x05

	maxStreams   = 4096
	idleSecs     = 120
	watchdogSecs = 30
	queueSize    = 512
	dialTimeout  = 3 * time.Second
	writeTimeout = 3 * time.Second
	maxPayload   = 16384
)

type userEntry struct {
	name    string
	expires time.Time
}

type userCache struct {
	mu       sync.RWMutex
	table    map[string]*userEntry
	loadedAt time.Time
}

var cache = &userCache{table: make(map[string]*userEntry)}

func (c *userCache) reload() {
	f, err := os.Open(usersFile)
	if err != nil {
		return
	}
	defer f.Close()
	t := make(map[string]*userEntry, 64)
	sc := bufio.NewScanner(f)
	for sc.Scan() {
		line := sc.Text()
		if len(line) == 0 || line[0] == '#' {
			continue
		}
		var id, name, exp string
		n := 0
		start := 0
		for i := 0; i <= len(line); i++ {
			if i == len(line) || line[i] == ':' {
				part := line[start:i]
				switch n {
				case 0:
					id = part
				case 1:
					name = part
				case 2:
					exp = part
				}
				n++
				start = i + 1
				if n == 3 {
					break
				}
			}
		}
		if n < 3 || id == "" || name == "" || exp == "" {
			continue
		}
		expires, err := time.ParseInLocation("2006-01-02", exp, time.Local)
		if err != nil {
			continue
		}
		expires = expires.Add(24*time.Hour - time.Second)
		t[id] = &userEntry{name: name, expires: expires}
	}
	c.mu.Lock()
	c.table = t
	c.loadedAt = time.Now()
	c.mu.Unlock()
}

func (c *userCache) lookup(id string) (*userEntry, bool) {
	c.mu.RLock()
	needReload := time.Since(c.loadedAt) > cacheReload
	e, ok := c.table[id]
	c.mu.RUnlock()
	if needReload {
		go c.reload()
	}
	return e, ok
}

type authResult int

const (
	authOK       authResult = iota
	authNotFound
	authExpired
)

func checkAuth(id string) (string, int, authResult) {
	e, ok := cache.lookup(id)
	if !ok {
		return "", 0, authNotFound
	}
	now := time.Now()
	if now.After(e.expires) {
		return e.name, 0, authExpired
	}
	days := int(e.expires.Sub(now).Hours()/24) + 1
	return e.name, days, authOK
}

var framePool = sync.Pool{New: func() interface{} { b := make([]byte, 7+maxPayload); return &b }}

func getFrame() []byte  { return *framePool.Get().(*[]byte) }
func putFrame(b []byte) { framePool.Put(&b) }

type stream struct {
	q      chan []byte
	active int64
	closed uint32
}

func newStream() *stream {
	return &stream{
		q:      make(chan []byte, queueSize),
		active: time.Now().Unix(),
	}
}

func (s *stream) tryClose() bool { return atomic.CompareAndSwapUint32(&s.closed, 0, 1) }
func (s *stream) isClosed() bool { return atomic.LoadUint32(&s.closed) == 1 }

type writeMsg struct {
	buf []byte
	n   int
}

type mux struct {
	conn    net.Conn
	writeQ  chan writeMsg
	mu      sync.RWMutex
	streams map[uint32]*stream
	count   int32
	dead    uint32
}

func newMux(conn net.Conn) *mux {
	m := &mux{
		conn:    conn,
		streams: make(map[uint32]*stream, 128),
		writeQ:  make(chan writeMsg, 2048),
	}
	go m.writeLoop()
	return m
}

func (m *mux) writeLoop() {
	for msg := range m.writeQ {
		if atomic.LoadUint32(&m.dead) == 0 {
			m.conn.SetWriteDeadline(time.Now().Add(writeTimeout))
			m.conn.Write(msg.buf[:msg.n])
			m.conn.SetWriteDeadline(time.Time{})
		}
		putFrame(msg.buf)
	}
}

func (m *mux) kill() {
	if atomic.CompareAndSwapUint32(&m.dead, 0, 1) {
		m.conn.Close()
		close(m.writeQ)
	}
}

func (m *mux) add(sid uint32, s *stream) bool {
	m.mu.Lock()
	defer m.mu.Unlock()
	if int(m.count) >= maxStreams {
		return false
	}
	m.streams[sid] = s
	atomic.AddInt32(&m.count, 1)
	return true
}

func (m *mux) get(sid uint32) *stream {
	m.mu.RLock()
	s := m.streams[sid]
	m.mu.RUnlock()
	return s
}

func (m *mux) del(sid uint32) {
	m.mu.Lock()
	if _, ok := m.streams[sid]; ok {
		delete(m.streams, sid)
		atomic.AddInt32(&m.count, -1)
	}
	m.mu.Unlock()
}

func (m *mux) send(t byte, sid uint32, data []byte) {
	if atomic.LoadUint32(&m.dead) == 1 {
		return
	}
	ln := len(data)
	buf := getFrame()
	buf[0] = t
	binary.BigEndian.PutUint32(buf[1:5], sid)
	binary.BigEndian.PutUint16(buf[5:7], uint16(ln))
	if ln > 0 {
		copy(buf[7:7+ln], data)
	}
	select {
	case m.writeQ <- writeMsg{buf: buf, n: 7 + ln}:
	default:
		putFrame(buf)
		m.kill()
	}
}

func (m *mux) sendHdr(t byte, sid uint32) {
	m.send(t, sid, nil)
}

func (m *mux) handleStream(sid uint32, s *stream, firstData []byte) {
	defer func() {
		if s.tryClose() {
			m.del(sid)
			m.sendHdr(tClose, sid)
			for {
				select {
				case d, ok := <-s.q:
					if !ok {
						return
					}
					putFrame(d[:cap(d)])
				default:
					return
				}
			}
		}
	}()

	hev, err := net.DialTimeout("tcp", hevTCPAddr, dialTimeout)
	if err != nil {
		return
	}
	defer hev.Close()

	tc := hev.(*net.TCPConn)
	tc.SetNoDelay(true)
	tc.SetReadBuffer(65536)
	tc.SetWriteBuffer(65536)

	if len(firstData) > 0 {
		if _, err := hev.Write(firstData); err != nil {
			return
		}
	}

	var wg sync.WaitGroup
	wg.Add(2)

	go func() {
		defer wg.Done()
		for d := range s.q {
			_, err := hev.Write(d)
			putFrame(d[:cap(d)])
			if err != nil {
				return
			}
			atomic.StoreInt64(&s.active, time.Now().Unix())
		}
	}()

	go func() {
		defer wg.Done()
		buf := make([]byte, maxPayload)
		for {
			n, err := hev.Read(buf)
			if n > 0 {
				m.send(tData, sid, buf[:n])
				atomic.StoreInt64(&s.active, time.Now().Unix())
			}
			if err != nil {
				return
			}
		}
	}()

	wg.Wait()
}

func (m *mux) watchdog() {
	ticker := time.NewTicker(watchdogSecs * time.Second)
	defer ticker.Stop()
	for range ticker.C {
		if atomic.LoadUint32(&m.dead) == 1 {
			return
		}
		now := time.Now().Unix()
		m.mu.RLock()
		toKill := make([]uint32, 0, 16)
		for sid, s := range m.streams {
			if now-atomic.LoadInt64(&s.active) > idleSecs {
				toKill = append(toKill, sid)
			}
		}
		m.mu.RUnlock()
		for _, sid := range toKill {
			m.mu.Lock()
			s, ok := m.streams[sid]
			if ok {
				delete(m.streams, sid)
				atomic.AddInt32(&m.count, -1)
			}
			m.mu.Unlock()
			if ok && s.tryClose() {
				close(s.q)
				m.sendHdr(tClose, sid)
			}
		}
	}
}

func (m *mux) run() {
	go m.watchdog()
	hdr     := make([]byte, 7)
	readBuf := make([]byte, maxPayload)
	for {
		if _, err := io.ReadFull(m.conn, hdr); err != nil {
			break
		}
		ft  := hdr[0]
		sid := binary.BigEndian.Uint32(hdr[1:5])
		ln  := binary.BigEndian.Uint16(hdr[5:7])
		if int(ln) > maxPayload {
			break
		}
		if ln > 0 {
			if _, err := io.ReadFull(m.conn, readBuf[:ln]); err != nil {
				break
			}
		}

		if ft == tPing {
			m.sendHdr(tPong, sid)
			continue
		}
		if ft == tPong {
			continue
		}

		switch ft {
		case tOpen:
			s := newStream()
			if !m.add(sid, s) {
				m.sendHdr(tClose, sid)
				continue
			}
			var first []byte
			if ln > 0 {
				first = make([]byte, ln)
				copy(first, readBuf[:ln])
			}
			go m.handleStream(sid, s, first)

		case tData:
			s := m.get(sid)
			if s == nil || s.isClosed() {
				continue
			}
			atomic.StoreInt64(&s.active, time.Now().Unix())
			buf := getFrame()
			copy(buf[7:7+ln], readBuf[:ln])
			payload := buf[7 : 7+ln]
			select {
			case s.q <- payload:
			default:
				putFrame(buf)
				if s.tryClose() {
					m.del(sid)
					close(s.q)
					m.sendHdr(tClose, sid)
				}
			}

		case tClose:
			s := m.get(sid)
			if s != nil && s.tryClose() {
				m.del(sid)
				close(s.q)
			}
		}
	}
	m.mu.Lock()
	for _, s := range m.streams {
		if s.tryClose() {
			close(s.q)
		}
	}
	m.mu.Unlock()
}

var activeSessions sync.Map

var (
	actionNeedle     = []byte("action:")
	internalIDNeedle = []byte("x-internal-id:")
	crlfcrlf         = []byte("\r\n\r\n")
	resp403NotReg    = []byte("HTTP/1.1 403 Forbidden\r\nContent-Type: text/plain\r\nContent-Length: 14\r\n\r\nnot_registered")
	resp403Expired   = []byte("HTTP/1.1 403 Forbidden\r\nContent-Type: text/plain\r\nContent-Length: 7\r\n\r\nexpired")
)

func indexBytes(s, sub []byte) int {
	if len(sub) == 0 {
		return 0
	}
	if len(s) < len(sub) {
		return -1
	}
	first := sub[0] | 0x20
	for i := 0; i <= len(s)-len(sub); i++ {
		if s[i]|0x20 != first {
			continue
		}
		match := true
		for j := 1; j < len(sub); j++ {
			if s[i+j]|0x20 != sub[j]|0x20 {
				match = false
				break
			}
		}
		if match {
			return i
		}
	}
	return -1
}

func extractHeader(raw []byte, needle []byte) string {
	start := 0
	for i := 0; i < len(raw); i++ {
		if raw[i] != '\n' {
			continue
		}
		end := i
		if end > start && raw[end-1] == '\r' {
			end--
		}
		line := raw[start:end]
		start = i + 1
		if len(line) <= len(needle) {
			continue
		}
		if indexBytes(line[:len(needle)], needle) != 0 {
			continue
		}
		val := line[len(needle):]
		for len(val) > 0 && (val[0] == ' ' || val[0] == '\t') {
			val = val[1:]
		}
		for len(val) > 0 && (val[len(val)-1] == ' ' || val[len(val)-1] == '\r') {
			val = val[:len(val)-1]
		}
		return string(val)
	}
	return ""
}

func handle(conn net.Conn) {
	defer conn.Close()
	tc, ok := conn.(*net.TCPConn)
	if !ok {
		return
	}
	tc.SetNoDelay(true)
	tc.SetReadBuffer(65536)
	tc.SetWriteBuffer(65536)
	tc.SetKeepAlive(true)
	tc.SetKeepAlivePeriod(30 * time.Second)

	buf := make([]byte, 4096)
	n := 0
	conn.SetReadDeadline(time.Now().Add(10 * time.Second))
	for n < len(buf) {
		nr, err := conn.Read(buf[n:])
		if nr > 0 {
			n += nr
			raw := buf[:n]
			if indexBytes(raw, actionNeedle) >= 0 && indexBytes(raw, crlfcrlf) >= 0 {
				break
			}
		}
		if err != nil {
			return
		}
	}
	conn.SetReadDeadline(time.Time{})

	raw := buf[:n]
	action := extractHeader(raw, actionNeedle)
	if action != "tunnel" {
		return
	}

	userID := extractHeader(raw, internalIDNeedle)
	if userID == "" {
		conn.Write(resp403NotReg)
		return
	}

	name, days, result := checkAuth(userID)
	switch result {
	case authNotFound:
		conn.Write(resp403NotReg)
		return
	case authExpired:
		conn.Write(resp403Expired)
		return
	}

	resp := fmt.Sprintf(
		"HTTP/1.1 101 Switching Protocols\r\nUpgrade: websocket\r\nConnection: Upgrade\r\nX-User-Name: %s\r\nX-User-Days: %d\r\n\r\n",
		name, days,
	)
	conn.Write([]byte(resp))

	m := newMux(conn)
	if prev, loaded := activeSessions.Swap(userID, m); loaded {
		prev.(*mux).kill()
	}
	m.run()
	activeSessions.CompareAndDelete(userID, m)
}

func tuneListener(ln net.Listener) {
	tc, ok := ln.(*net.TCPListener)
	if !ok {
		return
	}
	raw, err := tc.SyscallConn()
	if err != nil {
		return
	}
	raw.Control(func(fd uintptr) {
		syscall.SetsockoptInt(int(fd), syscall.IPPROTO_TCP, syscall.TCP_NODELAY, 1)
		syscall.SetsockoptInt(int(fd), syscall.SOL_SOCKET, syscall.SO_REUSEADDR, 1)
		syscall.SetsockoptInt(int(fd), syscall.SOL_SOCKET, 15, 1)
	})
}

func main() {
	runtime.GOMAXPROCS(runtime.NumCPU())
	cache.reload()
	go func() {
		t := time.NewTicker(cacheReload)
		defer t.Stop()
		for range t.C {
			cache.reload()
		}
	}()
	ln, err := net.Listen("tcp", listenAddr)
	if err != nil {
		log.Fatal(err)
	}
	tuneListener(ln)
	log.Printf("btserver %s -> hev:%s (cpus=%d)", listenAddr, hevTCPAddr, runtime.NumCPU())
	for {
		conn, err := ln.Accept()
		if err != nil {
			continue
		}
		go handle(conn)
	}
}
GOEOF

