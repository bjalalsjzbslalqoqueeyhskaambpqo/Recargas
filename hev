//go:build go1.20

package main

import (
	"bufio"
	"encoding/binary"
	"io"
	"log"
	"net"
	"net/http"
	"os"
	"runtime"
	"runtime/debug"
	"sync"
	"sync/atomic"
	"syscall"
	"time"
)

const (
	hevAddr      = "127.0.0.1:1080"
	listenAddr   = "0.0.0.0:80"
	usersFile    = "/opt/btserver/users.txt"
	tOpen        = byte(0x01)
	tData        = byte(0x02)
	tClose       = byte(0x03)
	tPing        = byte(0x04)
	tPong        = byte(0x05)
	tKick        = byte(0x06)
	tExpired     = byte(0x07)
	maxStreams   = 8192
	queueSize    = 64
	dialTimeout  = 100 * time.Millisecond
	writeTimeout = 5 * time.Second
	maxPayload   = 16384
)

type authResult int

const (
	authOK       authResult = iota
	authNotFound
	authExpired
)

func checkAuth(id string) (string, int, authResult) {
	f, err := os.Open(usersFile)
	if err != nil {
		return "", 0, authNotFound
	}
	defer f.Close()
	sc := bufio.NewScanner(f)
	for sc.Scan() {
		line := sc.Text()
		if len(line) == 0 || line[0] == '#' {
			continue
		}
		parts := [3]string{}
		n, start := 0, 0
		for i := 0; i <= len(line) && n < 3; i++ {
			if i == len(line) || line[i] == ':' {
				parts[n] = line[start:i]
				n++
				start = i + 1
			}
		}
		if n < 3 || parts[0] != id {
			continue
		}
		exp, err := time.ParseInLocation("2006-01-02", parts[2], time.Local)
		if err != nil {
			continue
		}
		expires := exp.Add(24*time.Hour - time.Second)
		if time.Now().After(expires) {
			return parts[1], 0, authExpired
		}
		return parts[1], int(time.Until(expires).Hours()/24) + 1, authOK
	}
	return "", 0, authNotFound
}

var (
	framePool = sync.Pool{New: func() interface{} {
		b := make([]byte, 7+maxPayload)
		return &b
	}}
	payloadPool = sync.Pool{New: func() interface{} {
		b := make([]byte, maxPayload)
		return &b
	}}
	readBufPool = sync.Pool{New: func() interface{} {
		b := make([]byte, maxPayload)
		return &b
	}}
)

func getFrame() []byte    { return *framePool.Get().(*[]byte) }
func putFrame(b []byte)   { framePool.Put(&b) }
func getPayload() []byte  { return *payloadPool.Get().(*[]byte) }
func putPayload(b []byte) { payloadPool.Put(&b) }

type stream struct {
	q      chan []byte
	closed atomic.Uint32
}

func (s *stream) tryClose() bool { return s.closed.CompareAndSwap(0, 1) }
func (s *stream) isClosed() bool { return s.closed.Load() == 1 }

type mux struct {
	conn    net.Conn
	writeQ  chan []byte
	mu      sync.RWMutex
	streams map[uint32]*stream
	count   atomic.Int32
	dead    atomic.Uint32
}

func newMux(conn net.Conn) *mux {
	m := &mux{
		conn:    conn,
		writeQ:  make(chan []byte, 4096),
		streams: make(map[uint32]*stream, 256),
	}
	go m.writeLoop()
	return m
}

func (m *mux) writeLoop() {
	var bufs net.Buffers
	var toFree [][]byte
	for buf := range m.writeQ {
		bufs = append(bufs[:0], buf)
		toFree = append(toFree[:0], buf)
	drain:
		for {
			select {
			case b := <-m.writeQ:
				bufs = append(bufs, b)
				toFree = append(toFree, b)
			default:
				break drain
			}
		}
		m.conn.SetWriteDeadline(time.Now().Add(writeTimeout))
		bufs.WriteTo(m.conn)
		m.conn.SetWriteDeadline(time.Time{})
		for _, b := range toFree {
			putFrame(b[:cap(b)])
		}
	}
}

func (m *mux) trySend(buf []byte) (ok bool) {
	defer func() {
		if recover() != nil {
			ok = false
		}
	}()
	select {
	case m.writeQ <- buf:
		return true
	default:
		return false
	}
}

func (m *mux) buildHdr(t byte, sid uint32) []byte {
	buf := getFrame()
	buf[0] = t
	binary.BigEndian.PutUint32(buf[1:5], sid)
	buf[5], buf[6] = 0, 0
	return buf[:7]
}

func (m *mux) send(t byte, sid uint32, data []byte) {
	if m.dead.Load() == 1 {
		return
	}
	ln := len(data)
	buf := getFrame()
	buf[0] = t
	binary.BigEndian.PutUint32(buf[1:5], sid)
	binary.BigEndian.PutUint16(buf[5:7], uint16(ln))
	if ln > 0 {
		copy(buf[7:7+ln], data)
	}
	if !m.trySend(buf[:7+ln]) {
		putFrame(buf)
	}
}

func (m *mux) sendHdr(t byte, sid uint32) {
	if m.dead.Load() == 1 {
		return
	}
	buf := m.buildHdr(t, sid)
	if !m.trySend(buf) {
		putFrame(buf[:cap(buf)])
	}
}

func (m *mux) sendNotify(t byte) {
	buf := m.buildHdr(t, 0)
	m.conn.SetWriteDeadline(time.Now().Add(writeTimeout))
	m.conn.Write(buf)
	m.conn.SetWriteDeadline(time.Time{})
	putFrame(buf[:cap(buf)])
}

func (m *mux) kill() {
	if m.dead.CompareAndSwap(0, 1) {
		m.conn.Close()
		close(m.writeQ)
	}
}

func (m *mux) killWithReason(t byte) {
	if !m.dead.CompareAndSwap(0, 1) {
		return
	}
	m.sendNotify(t)
	time.Sleep(50 * time.Millisecond)
	m.conn.Close()
	close(m.writeQ)
}

func (m *mux) addStream(sid uint32, s *stream) bool {
	m.mu.Lock()
	defer m.mu.Unlock()
	if int(m.count.Load()) >= maxStreams {
		return false
	}
	m.streams[sid] = s
	m.count.Add(1)
	return true
}

func (m *mux) getStream(sid uint32) *stream {
	m.mu.RLock()
	s := m.streams[sid]
	m.mu.RUnlock()
	return s
}

func (m *mux) delStream(sid uint32) {
	m.mu.Lock()
	if _, ok := m.streams[sid]; ok {
		delete(m.streams, sid)
		m.count.Add(-1)
	}
	m.mu.Unlock()
}

func (m *mux) closeStream(sid uint32) {
	s := m.getStream(sid)
	if s != nil && s.tryClose() {
		m.delStream(sid)
		close(s.q)
		go func() {
			for range s.q {
			}
		}()
	}
}

func (m *mux) handleStream(sid uint32, s *stream, first []byte) {
	defer func() {
		if s.tryClose() {
			m.delStream(sid)
			m.sendHdr(tClose, sid)
			for range s.q {
			}
		}
	}()

	hev, err := net.DialTimeout("tcp", hevAddr, dialTimeout)
	if err != nil {
		return
	}
	defer hev.Close()

	tc := hev.(*net.TCPConn)
	tc.SetNoDelay(true)
	tc.SetReadBuffer(262144)
	tc.SetWriteBuffer(262144)

	if len(first) > 0 {
		if _, err := hev.Write(first); err != nil {
			return
		}
	}

	var wg sync.WaitGroup
	wg.Add(2)

	go func() {
		defer wg.Done()
		for d := range s.q {
			_, err := hev.Write(d)
			putPayload(d[:cap(d)])
			if err != nil {
				break
			}
		}
		tc.CloseWrite()
	}()

	go func() {
		defer wg.Done()
		buf := *readBufPool.Get().(*[]byte)
		defer readBufPool.Put(&buf)
		for {
			n, err := hev.Read(buf)
			if n > 0 {
				m.send(tData, sid, buf[:n])
			}
			if err != nil {
				return
			}
		}
	}()

	wg.Wait()
}

func (m *mux) run() {
	hdr := make([]byte, 7)
	rb := make([]byte, maxPayload)

	for {
		if _, err := io.ReadFull(m.conn, hdr); err != nil {
			break
		}
		ft := hdr[0]
		sid := binary.BigEndian.Uint32(hdr[1:5])
		ln := int(binary.BigEndian.Uint16(hdr[5:7]))
		if ln > maxPayload {
			break
		}
		if ln > 0 {
			if _, err := io.ReadFull(m.conn, rb[:ln]); err != nil {
				break
			}
		}

		switch ft {
		case tPing:
			m.sendHdr(tPong, sid)
		case tPong:
		case tOpen:
			s := &stream{q: make(chan []byte, queueSize)}
			if !m.addStream(sid, s) {
				m.sendHdr(tClose, sid)
				continue
			}
			var first []byte
			if ln > 0 {
				first = make([]byte, ln)
				copy(first, rb[:ln])
			}
			go m.handleStream(sid, s, first)
		case tData:
			s := m.getStream(sid)
			if s == nil || s.isClosed() {
				continue
			}
			p := getPayload()[:ln]
			copy(p, rb[:ln])
			select {
			case s.q <- p:
			default:
				putPayload(p[:cap(p)])
			}
		case tClose:
			m.closeStream(sid)
		}
	}

	m.mu.Lock()
	for _, s := range m.streams {
		if s.tryClose() {
			close(s.q)
		}
	}
	m.mu.Unlock()
}

var activeSessions = sync.Map{}

func kickSession(id string, reason byte) bool {
	if v, ok := activeSessions.LoadAndDelete(id); ok {
		m := v.(*mux)
		m.killWithReason(reason)
		log.Printf("session kicked id=%s reason=0x%02x streams=%d", id, reason, m.count.Load())
		return true
	}
	return false
}

var (
	needleAction = []byte("action:")
	needleID     = []byte("x-internal-id:")
	needleEnd    = []byte("\r\n\r\n")
)

func bytesIndex(s, sub []byte) int {
	if len(sub) == 0 || len(s) < len(sub) {
		return -1
	}
	f := sub[0] | 0x20
	for i := 0; i <= len(s)-len(sub); i++ {
		if s[i]|0x20 != f {
			continue
		}
		ok := true
		for j := 1; j < len(sub); j++ {
			if s[i+j]|0x20 != sub[j]|0x20 {
				ok = false
				break
			}
		}
		if ok {
			return i
		}
	}
	return -1
}

func extractHeader(raw, needle []byte) string {
	start := 0
	for i := 0; i < len(raw); i++ {
		if raw[i] != '\n' {
			continue
		}
		end := i
		if end > start && raw[end-1] == '\r' {
			end--
		}
		line := raw[start:end]
		start = i + 1
		if len(line) <= len(needle) || bytesIndex(line[:len(needle)], needle) != 0 {
			continue
		}
		val := line[len(needle):]
		for len(val) > 0 && (val[0] == ' ' || val[0] == '\t') {
			val = val[1:]
		}
		for len(val) > 0 && (val[len(val)-1] == ' ' || val[len(val)-1] == '\r') {
			val = val[:len(val)-1]
		}
		return string(val)
	}
	return ""
}

func itoa(n int) string {
	if n == 0 {
		return "0"
	}
	b := make([]byte, 20)
	i := len(b)
	for n > 0 {
		i--
		b[i] = byte('0' + n%10)
		n /= 10
	}
	return string(b[i:])
}

func write403(conn net.Conn, reason, body string) {
	resp := "HTTP/1.1 403 Forbidden\r\nX-Disconnect-Reason: " + reason +
		"\r\nContent-Length: " + itoa(len(body)) + "\r\n\r\n" + body
	conn.Write([]byte(resp))
}

func handle(conn net.Conn) {
	defer conn.Close()
	tc := conn.(*net.TCPConn)
	tc.SetNoDelay(true)
	tc.SetReadBuffer(262144)
	tc.SetWriteBuffer(262144)
	tc.SetKeepAlive(true)
	tc.SetKeepAlivePeriod(30 * time.Second)

	buf := make([]byte, 4096)
	n := 0
	conn.SetReadDeadline(time.Now().Add(10 * time.Second))
	for n < len(buf) {
		nr, err := conn.Read(buf[n:])
		if nr > 0 {
			n += nr
			if bytesIndex(buf[:n], needleAction) >= 0 && bytesIndex(buf[:n], needleEnd) >= 0 {
				break
			}
		}
		if err != nil {
			return
		}
	}
	conn.SetReadDeadline(time.Time{})

	raw := buf[:n]
	action := extractHeader(raw, needleAction)
	if action != "tunnel" && action != "tunnel-tcp" {
		return
	}

	userID := extractHeader(raw, needleID)
	if userID == "" {
		write403(conn, "not_registered", "not_registered")
		return
	}

	name, days, res := checkAuth(userID)
	switch res {
	case authNotFound:
		write403(conn, "not_registered", "not_registered")
		return
	case authExpired:
		write403(conn, "expired", "expired")
		return
	}

	conn.Write([]byte("HTTP/1.1 101 Switching Protocols\r\nUpgrade: websocket\r\nConnection: Upgrade\r\nX-User-Name: " +
		name + "\r\nX-User-Days: " + itoa(days) + "\r\n\r\n"))

	m := newMux(conn)
	if prev, loaded := activeSessions.Swap(userID, m); loaded {
		go prev.(*mux).killWithReason(tKick)
	}
	m.run()
	activeSessions.CompareAndDelete(userID, m)
}

func kickHandler(w http.ResponseWriter, r *http.Request) {
	id := r.URL.Query().Get("id")
	reason := tKick
	if r.URL.Query().Get("reason") == "expired" {
		reason = tExpired
	}
	if id == "" {
		w.WriteHeader(400)
		w.Write([]byte("missing_id"))
		return
	}
	if kickSession(id, byte(reason)) {
		log.Printf("kick api: session %s terminated", id)
		w.Write([]byte("kicked"))
		return
	}
	log.Printf("kick api: session %s not found", id)
	w.Write([]byte("not_connected"))
}

func nextMidnight() time.Time {
	now := time.Now()
	return time.Date(now.Year(), now.Month(), now.Day()+1, 0, 0, 0, 0, time.Local)
}

func checkExpiredSessions() {
	kicked := 0
	activeSessions.Range(func(key, value any) bool {
		userID := key.(string)
		_, _, res := checkAuth(userID)
		if res != authOK {
			reason := tExpired
			if res == authNotFound {
				reason = tKick
			}
			kickSession(userID, byte(reason))
			kicked++
		}
		return true
	})
	if kicked > 0 {
		log.Printf("midnight check: kicked %d sessions", kicked)
	}
}

func main() {
	runtime.GOMAXPROCS(runtime.NumCPU())
	debug.SetMemoryLimit(768 << 20)

	go func() {
		for {
			time.Sleep(time.Until(nextMidnight()))
			checkExpiredSessions()
		}
	}()

	go func() {
		mux := http.NewServeMux()
		mux.HandleFunc("/kick", kickHandler)
		srv := &http.Server{
			Addr:         "127.0.0.1:8091",
			Handler:      mux,
			ReadTimeout:  5 * time.Second,
			WriteTimeout: 5 * time.Second,
		}
		log.Printf("kick api on 127.0.0.1:8091")
		if err := srv.ListenAndServe(); err != nil {
			log.Printf("kick api error: %v", err)
		}
	}()

	ln, err := net.Listen("tcp", listenAddr)
	if err != nil {
		log.Fatal(err)
	}
	if tc, ok := ln.(*net.TCPListener); ok {
		if raw, err := tc.SyscallConn(); err == nil {
			raw.Control(func(fd uintptr) {
				syscall.SetsockoptInt(int(fd), syscall.IPPROTO_TCP, syscall.TCP_NODELAY, 1)
				syscall.SetsockoptInt(int(fd), syscall.SOL_SOCKET, syscall.SO_REUSEADDR, 1)
				syscall.SetsockoptInt(int(fd), syscall.SOL_SOCKET, 15, 1)
			})
		}
	}

	log.Printf("btserver %s -> hev %s (go=%s cpus=%d)", listenAddr, hevAddr, runtime.Version(), runtime.NumCPU())
	for {
		conn, err := ln.Accept()
		if err != nil {
			continue
		}
		go handle(conn)
	}
}
GOEOF

