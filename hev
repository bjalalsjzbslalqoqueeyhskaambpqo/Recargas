const (
	hevTCPAddr  = "127.0.0.1:1080"
	hevUDPAddr  = "127.0.0.1:1080"
	listenAddr  = "0.0.0.0:80"
	usersFile   = "/opt/btserver/users.txt"
	cacheReload = 30 * time.Second

	tOpen  byte = 0x01
	tData  byte = 0x02
	tClose byte = 0x03
	tPing  byte = 0x04
	tPong  byte = 0x05

	sidCtrlMin = uint32(0x40000000)
	sidCtrlMax = uint32(0x7FFFFFFF)

	maxStreams   = 8192
	idleSecs     = 3600
	watchdogSecs = 60
	queueSize    = 1024
	dialTimeout  = 1500 * time.Millisecond
	writeTimeout = 5 * time.Second
	maxPayload   = 16384

	dnsTTL = 2 * time.Hour
)

type dnsEntry struct {
	ips    []string
	expiry int64
}

var dnsCache sync.Map

func resolveHost(host string) (string, error) {
	now := time.Now().Unix()
	if v, ok := dnsCache.Load(host); ok {
		e := v.(*dnsEntry)
		if now < e.expiry {
			return e.ips[0], nil
		}
	}
	addrs, err := net.LookupHost(host)
	if err != nil || len(addrs) == 0 {
		return "", err
	}
	entry := &dnsEntry{ips: addrs}
	entry.expiry = time.Now().Add(dnsTTL).Unix()
	dnsCache.Store(host, entry)
	return addrs[0], nil
}

type userEntry struct {
	name    string
	expires time.Time
}

type userCache struct {
	mu       sync.RWMutex
	table    map[string]*userEntry
	loadedAt time.Time
}

var cache = &userCache{table: make(map[string]*userEntry)}

func (c *userCache) reload() {
	f, err := os.Open(usersFile)
	if err != nil {
		return
	}
	defer f.Close()
	t := make(map[string]*userEntry, 64)
	sc := bufio.NewScanner(f)
	for sc.Scan() {
		line := sc.Text()
		if len(line) == 0 || line[0] == '#' {
			continue
		}
		var id, name, exp string
		n := 0
		start := 0
		for i := 0; i <= len(line); i++ {
			if i == len(line) || line[i] == ':' {
				part := line[start:i]
				switch n {
				case 0:
					id = part
				case 1:
					name = part
				case 2:
					exp = part
				}
				n++
				start = i + 1
				if n == 3 {
					break
				}
			}
		}
		if n < 3 || id == "" || name == "" || exp == "" {
			continue
		}
		expires, err := time.ParseInLocation("2006-01-02", exp, time.Local)
		if err != nil {
			continue
		}
		expires = expires.Add(24*time.Hour - time.Second)
		t[id] = &userEntry{name: name, expires: expires}
	}
	c.mu.Lock()
	c.table = t
	c.loadedAt = time.Now()
	c.mu.Unlock()
}

func (c *userCache) lookup(id string) (*userEntry, bool) {
	c.mu.RLock()
	needReload := time.Since(c.loadedAt) > cacheReload
	e, ok := c.table[id]
	c.mu.RUnlock()
	if needReload {
		go c.reload()
	}
	return e, ok
}

type authResult int

const (
	authOK       authResult = iota
	authNotFound
	authExpired
)

func checkAuth(id string) (string, int, authResult) {
	e, ok := cache.lookup(id)
	if !ok {
		return "", 0, authNotFound
	}
	now := time.Now()
	if now.After(e.expires) {
		return e.name, 0, authExpired
	}
	days := int(e.expires.Sub(now).Hours()/24) + 1
	return e.name, days, authOK
}

var framePool = sync.Pool{New: func() interface{} { b := make([]byte, 7+maxPayload); return &b }}

func getFrame() []byte  { return *framePool.Get().(*[]byte) }
func putFrame(b []byte) { framePool.Put(&b) }

type stream struct {
	q      chan []byte
	active atomic.Int64
	closed atomic.Uint32
}

func (s *stream) tryClose() bool { return s.closed.CompareAndSwap(0, 1) }
func (s *stream) isClosed() bool { return s.closed.Load() == 1 }

type mux struct {
	conn    net.Conn
	writeQ  chan []byte
	mu      sync.RWMutex
	streams map[uint32]*stream
	count   atomic.Int32
	dead    atomic.Uint32
}

func newMux(conn net.Conn) *mux {
	m := &mux{
		conn:    conn,
		writeQ:  make(chan []byte, 4096),
		streams: make(map[uint32]*stream, 512),
	}
	go m.writeLoop()
	return m
}

func (m *mux) writeLoop() {
	for buf := range m.writeQ {
		if m.dead.Load() == 0 {
			m.conn.SetWriteDeadline(time.Now().Add(writeTimeout))
			m.conn.Write(buf)
			m.conn.SetWriteDeadline(time.Time{})
		}
		putFrame(buf[:cap(buf)])
	}
}

func (m *mux) kill() {
	if m.dead.CompareAndSwap(0, 1) {
		m.conn.Close()
		close(m.writeQ)
	}
}

func (m *mux) add(sid uint32, s *stream) bool {
	m.mu.Lock()
	defer m.mu.Unlock()
	if int(m.count.Load()) >= maxStreams {
		return false
	}
	m.streams[sid] = s
	m.count.Add(1)
	return true
}

func (m *mux) get(sid uint32) *stream {
	m.mu.RLock()
	s := m.streams[sid]
	m.mu.RUnlock()
	return s
}

func (m *mux) del(sid uint32) {
	m.mu.Lock()
	if _, ok := m.streams[sid]; ok {
		delete(m.streams, sid)
		m.count.Add(-1)
	}
	m.mu.Unlock()
}

func (m *mux) send(t byte, sid uint32, data []byte) {
	if m.dead.Load() == 1 {
		return
	}
	ln := len(data)
	buf := getFrame()
	buf[0] = t
	binary.BigEndian.PutUint32(buf[1:5], sid)
	binary.BigEndian.PutUint16(buf[5:7], uint16(ln))
	if ln > 0 {
		copy(buf[7:7+ln], data)
	}
	select {
	case m.writeQ <- buf[:7+ln]:
	default:
		putFrame(buf)
	}
}

func (m *mux) sendHdr(t byte, sid uint32) {
	if m.dead.Load() == 1 {
		return
	}
	buf := getFrame()
	buf[0] = t
	binary.BigEndian.PutUint32(buf[1:5], sid)
	buf[5] = 0
	buf[6] = 0
	select {
	case m.writeQ <- buf[:7]:
	default:
		putFrame(buf)
	}
}

func parseSocks5Host(data []byte) (host string, port uint16, headerLen int) {
	if len(data) < 4 || data[0] != 0x05 {
		return "", 0, 0
	}
	switch data[3] {
	case 0x01:
		if len(data) < 10 {
			return "", 0, 0
		}
		host = net.IP(data[4:8]).String()
		port = binary.BigEndian.Uint16(data[8:10])
		headerLen = 10
	case 0x03:
		if len(data) < 5 {
			return "", 0, 0
		}
		l := int(data[4])
		if len(data) < 5+l+2 {
			return "", 0, 0
		}
		host = string(data[5 : 5+l])
		port = binary.BigEndian.Uint16(data[5+l : 5+l+2])
		headerLen = 5 + l + 2
	case 0x04:
		if len(data) < 22 {
			return "", 0, 0
		}
		host = net.IP(data[4:20]).String()
		port = binary.BigEndian.Uint16(data[20:22])
		headerLen = 22
	}
	return
}

func (m *mux) handleStream(sid uint32, s *stream, firstData []byte) {
	defer func() {
		if s.tryClose() {
			m.del(sid)
			m.sendHdr(tClose, sid)
			for range s.q {
			}
		}
	}()

	target := hevTCPAddr
	if len(firstData) >= 10 && firstData[0] == 0x05 {
		host, port, _ := parseSocks5Host(firstData)
		if host != "" {
			if port == 0 {
				port = 80
			}
			if resolved, err := resolveHost(host); err == nil {
				target = fmt.Sprintf("%s:%d", resolved, port)
			}
		}
	}

	hev, err := net.DialTimeout("tcp", target, dialTimeout)
	if err != nil {
		if target != hevTCPAddr {
			hev, err = net.DialTimeout("tcp", hevTCPAddr, dialTimeout)
		}
		if err != nil {
			return
		}
	}
	defer hev.Close()

	tc := hev.(*net.TCPConn)
	tc.SetNoDelay(true)
	tc.SetReadBuffer(65536)
	tc.SetWriteBuffer(65536)

	if len(firstData) > 0 {
		if _, err := hev.Write(firstData); err != nil {
			return
		}
	}

	var wg sync.WaitGroup
	wg.Add(2)

	go func() {
		defer wg.Done()
		for d := range s.q {
			if _, err := hev.Write(d); err != nil {
				break
			}
			s.active.Store(time.Now().Unix())
		}
		tc.CloseWrite()
	}()

	go func() {
		defer wg.Done()
		buf := make([]byte, maxPayload)
		for {
			n, err := hev.Read(buf)
			if n > 0 {
				m.send(tData, sid, buf[:n])
				s.active.Store(time.Now().Unix())
			}
			if err != nil {
				return
			}
		}
	}()

	wg.Wait()
}

func (m *mux) watchdog() {
	ticker := time.NewTicker(watchdogSecs * time.Second)
	defer ticker.Stop()
	for range ticker.C {
		if m.dead.Load() == 1 {
			return
		}
		now := time.Now().Unix()
		m.mu.RLock()
		toKill := make([]uint32, 0, 16)
		for sid, s := range m.streams {
			if now-s.active.Load() > idleSecs {
				toKill = append(toKill, sid)
			}
		}
		m.mu.RUnlock()
		for _, sid := range toKill {
			m.mu.Lock()
			s, ok := m.streams[sid]
			if ok {
				delete(m.streams, sid)
				m.count.Add(-1)
			}
			m.mu.Unlock()
			if ok && s.tryClose() {
				close(s.q)
				m.sendHdr(tClose, sid)
			}
		}
	}
}

func (m *mux) run() {
	go m.watchdog()
	hdr     := make([]byte, 7)
	readBuf := make([]byte, maxPayload)
	for {
		if _, err := io.ReadFull(m.conn, hdr); err != nil {
			break
		}
		ft  := hdr[0]
		sid := binary.BigEndian.Uint32(hdr[1:5])
		ln  := binary.BigEndian.Uint16(hdr[5:7])
		if int(ln) > maxPayload {
			break
		}
		var data []byte
		if ln > 0 {
			if _, err := io.ReadFull(m.conn, readBuf[:ln]); err != nil {
				break
			}
			data = readBuf[:ln]
		}

		if ft == tPing {
			m.sendHdr(tPong, sid)
			continue
		}
		if ft == tPong || (sid >= sidCtrlMin && sid <= sidCtrlMax) {
			continue
		}

		switch ft {
		case tOpen:
			s := &stream{q: make(chan []byte, queueSize), }
			if !m.add(sid, s) {
				m.sendHdr(tClose, sid)
				continue
			}
			var first []byte
			if ln > 0 {
				first = make([]byte, ln)
				copy(first, data)
			}
			go m.handleStream(sid, s, first)
		case tData:
			s := m.get(sid)
			if s == nil || s.isClosed() {
				continue
			}
			s.active.Store(time.Now().Unix())
			payload := make([]byte, ln)
			copy(payload, data)
			select {
			case s.q <- payload:
			default:
				if s.tryClose() {
					m.del(sid)
					close(s.q)
					m.sendHdr(tClose, sid)
				}
			}
		case tClose:
			s := m.get(sid)
			if s != nil && s.tryClose() {
				m.del(sid)
				close(s.q)
			}
		}
	}
	m.mu.Lock()
	for _, s := range m.streams {
		if s.tryClose() {
			close(s.q)
		}
	}
	m.mu.Unlock()
}

type udpSession struct {
	conn net.Conn
	dead atomic.Uint32
}

func (u *udpSession) kill() {
	if u.dead.CompareAndSwap(0, 1) {
		u.conn.Close()
	}
}

func runUDPTunnel(conn net.Conn) {
	defer conn.Close()
	hevUDP, err := net.Dial("udp", hevUDPAddr)
	if err != nil {
		return
	}
	defer hevUDP.Close()
	var wg sync.WaitGroup
	wg.Add(2)
	go func() {
		defer wg.Done()
		buf := make([]byte, maxPayload)
		for {
			n, err := conn.Read(buf)
			if n > 0 {
				hevUDP.SetWriteDeadline(time.Now().Add(writeTimeout))
				hevUDP.Write(buf[:n])
			}
			if err != nil {
				return
			}
		}
	}()
	go func() {
		defer wg.Done()
		buf := make([]byte, maxPayload)
		for {
			hevUDP.SetReadDeadline(time.Now().Add(60 * time.Second))
			n, err := hevUDP.Read(buf)
			if n > 0 {
				conn.SetWriteDeadline(time.Now().Add(writeTimeout))
				conn.Write(buf[:n])
			}
			if err != nil {
				return
			}
		}
	}()
	wg.Wait()
}

var activeSessions    sync.Map
var activeUDPSessions sync.Map

var (
	actionNeedle     = []byte("action:")
	internalIDNeedle = []byte("x-internal-id:")
	crlfcrlf         = []byte("\r\n\r\n")
	resp403NotReg    = []byte("HTTP/1.1 403 Forbidden\r\nContent-Type: text/plain\r\nContent-Length: 14\r\n\r\nnot_registered")
	resp403Expired   = []byte("HTTP/1.1 403 Forbidden\r\nContent-Type: text/plain\r\nContent-Length: 7\r\n\r\nexpired")
)

func indexBytes(s, sub []byte) int {
	if len(sub) == 0 {
		return 0
	}
	if len(s) < len(sub) {
		return -1
	}
	first := sub[0] | 0x20
	for i := 0; i <= len(s)-len(sub); i++ {
		if s[i]|0x20 != first {
			continue
		}
		match := true
		for j := 1; j < len(sub); j++ {
			if s[i+j]|0x20 != sub[j]|0x20 {
				match = false
				break
			}
		}
		if match {
			return i
		}
	}
	return -1
}

func extractHeader(raw []byte, needle []byte) string {
	start := 0
	for i := 0; i < len(raw); i++ {
		if raw[i] != '\n' {
			continue
		}
		end := i
		if end > start && raw[end-1] == '\r' {
			end--
		}
		line := raw[start:end]
		start = i + 1
		if len(line) <= len(needle) {
			continue
		}
		if indexBytes(line[:len(needle)], needle) != 0 {
			continue
		}
		val := line[len(needle):]
		for len(val) > 0 && (val[0] == ' ' || val[0] == '\t') {
			val = val[1:]
		}
		for len(val) > 0 && (val[len(val)-1] == ' ' || val[len(val)-1] == '\r') {
			val = val[:len(val)-1]
		}
		return string(val)
	}
	return ""
}

func handle(conn net.Conn) {
	defer conn.Close()
	tc, ok := conn.(*net.TCPConn)
	if !ok {
		return
	}
	tc.SetNoDelay(true)
	tc.SetReadBuffer(65536)
	tc.SetWriteBuffer(65536)
	tc.SetKeepAlive(true)
	tc.SetKeepAlivePeriod(30 * time.Second)

	buf := make([]byte, 4096)
	n := 0
	conn.SetReadDeadline(time.Now().Add(10 * time.Second))
	for n < len(buf) {
		nr, err := conn.Read(buf[n:])
		if nr > 0 {
			n += nr
			raw := buf[:n]
			if indexBytes(raw, actionNeedle) >= 0 && indexBytes(raw, crlfcrlf) >= 0 {
				break
			}
		}
		if err != nil {
			return
		}
	}
	conn.SetReadDeadline(time.Time{})

	raw := buf[:n]
	action := extractHeader(raw, actionNeedle)
	if action != "tunnel" && action != "tunnel-tcp" && action != "tunnel-udp" {
		return
	}

	userID := extractHeader(raw, internalIDNeedle)
	if userID == "" {
		conn.Write(resp403NotReg)
		return
	}

	name, days, result := checkAuth(userID)
	switch result {
	case authNotFound:
		conn.Write(resp403NotReg)
		return
	case authExpired:
		conn.Write(resp403Expired)
		return
	}

	conn.Write([]byte(fmt.Sprintf(
		"HTTP/1.1 101 Switching Protocols\r\nUpgrade: websocket\r\nConnection: Upgrade\r\nX-User-Name: %s\r\nX-User-Days: %d\r\n\r\n",
		name, days,
	)))

	if action == "tunnel-udp" {
		u := &udpSession{conn: conn}
		if prev, loaded := activeUDPSessions.Swap(userID, u); loaded {
			prev.(*udpSession).kill()
		}
		runUDPTunnel(conn)
		activeUDPSessions.CompareAndDelete(userID, u)
	} else {
		m := newMux(conn)
		if prev, loaded := activeSessions.Swap(userID, m); loaded {
			prev.(*mux).kill()
		}
		m.run()
		activeSessions.CompareAndDelete(userID, m)
	}
}

func main() {
	runtime.GOMAXPROCS(runtime.NumCPU())
	debug.SetMemoryLimit(768 << 20)
	cache.reload()
	go func() {
		t := time.NewTicker(cacheReload)
		defer t.Stop()
		for range t.C {
			cache.reload()
		}
	}()
	ln, err := net.Listen("tcp", listenAddr)
	if err != nil {
		log.Fatal(err)
	}
	if tc, ok := ln.(*net.TCPListener); ok {
		if raw, err := tc.SyscallConn(); err == nil {
			raw.Control(func(fd uintptr) {
				syscall.SetsockoptInt(int(fd), syscall.IPPROTO_TCP, syscall.TCP_NODELAY, 1)
				syscall.SetsockoptInt(int(fd), syscall.SOL_SOCKET, syscall.SO_REUSEADDR, 1)
				syscall.SetsockoptInt(int(fd), syscall.SOL_SOCKET, 15, 1)
			})
		}
	}
	log.Printf("btserver %s -> hev tcp:%s (go=%s cpus=%d)", listenAddr, hevTCPAddr, runtime.Version(), runtime.NumCPU())
	for {
		conn, err := ln.Accept()
		if err != nil {
			continue
		}
		go handle(conn)
	}
}
