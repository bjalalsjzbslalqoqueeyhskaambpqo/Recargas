#!/usr/bin/env python3
import json, time, os, threading
from http.server import BaseHTTPRequestHandler, HTTPServer
from pathlib import Path
from urllib.parse import urlparse, parse_qs
from datetime import datetime, timedelta, timezone

USERS_FILE = Path("/opt/btserver/users.txt")
TOKEN_FILE = Path("/opt/btserver/token.txt")
PORT = ${PANEL_PORT}
_lock = threading.Lock()

def load_token():
    return TOKEN_FILE.read_text().strip()

def date_to_str(d):
    return d.strftime("%Y-%m-%d")

def str_to_date(s):
    return datetime.strptime(s.strip(), "%Y-%m-%d").date()

def days_left(exp_str):
    try:
        exp = str_to_date(exp_str)
        delta = (exp - datetime.now().date()).days + 1
        return max(0, delta)
    except:
        return 0

def is_active(exp_str):
    return days_left(exp_str) > 0

def load_users():
    users = {}
    if not USERS_FILE.exists():
        return users
    with open(USERS_FILE, "r") as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            parts = line.split(":", 2)
            if len(parts) < 3:
                continue
            uid, name, exp = parts[0].strip(), parts[1].strip(), parts[2].strip()
            if uid:
                users[uid] = {"name": name, "expires": exp}
    return users

def save_users(users):
    lines = ["# formato: id:nombre:YYYY-MM-DD\n"]
    for uid, data in sorted(users.items()):
        lines.append(f"{uid}:{data['name']}:{data['expires']}\n")
    with open(USERS_FILE, "w") as f:
        f.writelines(lines)

def json_resp(handler, code, data):
    body = json.dumps(data, ensure_ascii=False).encode()
    handler.send_response(code)
    handler.send_header("Content-Type", "application/json; charset=utf-8")
    handler.send_header("Content-Length", str(len(body)))
    handler.end_headers()
    handler.wfile.write(body)

class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args): pass

    def auth(self):
        return self.headers.get("X-Token", "").strip() == load_token()

    def read_body(self):
        length = int(self.headers.get("Content-Length", "0"))
        if length == 0: return {}
        try: return json.loads(self.rfile.read(length).decode())
        except: return {}

    def do_GET(self):
        if not self.auth(): json_resp(self, 401, {"error": "unauthorized"}); return
        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/")
        params = parse_qs(parsed.query)

        if path == "/clients":
            with _lock:
                users = load_users()
            result = []
            for uid, data in sorted(users.items()):
                result.append({
                    "id": uid,
                    "name": data["name"],
                    "expires": data["expires"],
                    "days_left": days_left(data["expires"]),
                    "active": is_active(data["expires"])
                })
            json_resp(self, 200, {"clients": result, "total": len(result)})
            return

        if path == "/client":
            uid = params.get("id", [""])[0].strip()
            if not uid: json_resp(self, 400, {"error": "falta id"}); return
            with _lock:
                users = load_users()
            if uid not in users: json_resp(self, 404, {"error": "no encontrado"}); return
            data = users[uid]
            json_resp(self, 200, {
                "id": uid, "name": data["name"],
                "expires": data["expires"],
                "days_left": days_left(data["expires"]),
                "active": is_active(data["expires"])
            })
            return

        json_resp(self, 404, {"error": "ruta no encontrada"})

    def do_POST(self):
        if not self.auth(): json_resp(self, 401, {"error": "unauthorized"}); return
        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/")
        body = self.read_body()

        if path == "/client/create":
            uid  = str(body.get("id", "")).strip()
            name = str(body.get("name", "sin-nombre")).strip() or "sin-nombre"
            days = int(body.get("days", 30))
            if not uid: json_resp(self, 400, {"error": "falta id"}); return
            exp = date_to_str((datetime.now() + timedelta(days=max(days, 0))).date())
            with _lock:
                users = load_users()
                users[uid] = {"name": name, "expires": exp}
                save_users(users)
            json_resp(self, 200, {"ok": True, "id": uid, "name": name, "expires": exp, "days": days})
            return

        if path == "/client/delete":
            uid = str(body.get("id", "")).strip()
            if not uid: json_resp(self, 400, {"error": "falta id"}); return
            with _lock:
                users = load_users()
                if uid not in users: json_resp(self, 404, {"error": "no encontrado"}); return
                users.pop(uid)
                save_users(users)
            json_resp(self, 200, {"ok": True})
            return

        if path == "/client/update":
            uid = str(body.get("id", "")).strip()
            if not uid: json_resp(self, 400, {"error": "falta id"}); return
            with _lock:
                users = load_users()
                if uid not in users: json_resp(self, 404, {"error": "no encontrado"}); return
                item = users[uid]
                if "name" in body:
                    item["name"] = str(body["name"]).strip() or "sin-nombre"
                try:
                    cur_exp = str_to_date(item["expires"])
                except:
                    cur_exp = datetime.now().date()
                base = cur_exp if cur_exp > datetime.now().date() else datetime.now().date()
                if "add_days" in body:
                    item["expires"] = date_to_str(base + timedelta(days=max(int(body["add_days"]), 0)))
                elif "sub_days" in body:
                    item["expires"] = date_to_str(cur_exp - timedelta(days=max(int(body["sub_days"]), 0)))
                elif "set_days" in body:
                    item["expires"] = date_to_str((datetime.now() + timedelta(days=max(int(body["set_days"]), 0))).date())
                elif "set_date" in body:
                    item["expires"] = str(body["set_date"]).strip()
                new_id = str(body.get("new_id", "")).strip()
                if new_id and new_id != uid:
                    users.pop(uid)
                    users[new_id] = item
                    uid = new_id
                else:
                    users[uid] = item
                save_users(users)
            json_resp(self, 200, {
                "ok": True, "id": uid,
                "name": item["name"],
                "expires": item["expires"],
                "days_left": days_left(item["expires"])
            })
            return

        json_resp(self, 404, {"error": "ruta no encontrada"})

if __name__ == "__main__":
    print(f"panel api escuchando :{PORT}")
    HTTPServer(("0.0.0.0", PORT), Handler).serve_forever()
